module main
  ports:
    in  clk 1bu
    in  rst 1bu
  signals:
    const_0  const 1bu = true
    const_1  const 8bu = 171
    const_12 const 16bu = 15
    const_14 const 16bu = 255
    const_16 const 32bs = 0
    const_17 const 32bs = 0
    const_18 const 32bs = 0
    const_3  const 32bu = 8
    const_6  const 8bu = 205
    const_9  const 32bu = 12
    shift_11 wire  16bu
    shift_5  wire  16bu
    t0_2     wire  16bu
    t1_4     wire  16bu
    t2_7     wire  16bu
    t3_8     wire  16bu
    t4_10    wire  16bu
    t5_13    wire  16bu
    t6_15    wire  16bu
    varargs  reg   32bs
  process 0 main (stage=0, sequential)
    block entry
      t0_2 := convert(const_1)
      shift_5 := convert(const_3)
      t1_4 := t0_2 << shift_5
      t2_7 := convert(const_6)
      t3_8 := t1_4 | t2_7
      shift_11 := convert(const_9)
      t4_10 := t3_8 >> shift_11
      t5_13 := t4_10 & const_12
      t6_15 := t3_8 & const_14
      print "word=0x"%0x(t3_8)" high="%0d(t5_13)" low=0x"%0x(t6_15)"\n"
      return

