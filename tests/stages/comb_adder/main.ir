module main
  ports:
    in  clk 1bu
    in  rst 1bu
  signals:
    const_0  const 1bu = true
    const_1  const 16bs = -12
    const_11 const 32bs = 0
    const_12 const 32bs = 0
    const_3  const 16bs = 25
    const_8  const 16bu = 4660
    t0_2     wire  32bs
    t1_4     wire  32bs
    t2_5     wire  32bs
    t3_6     wire  16bu
    t4_7     wire  32bu
    t5_9     wire  32bu
    t6_10    wire  32bu
    varargs  reg   32bs
  process 0 main (stage=0, sequential)
    block entry
      t0_2 := convert(const_1)
      t1_4 := convert(const_3)
      t2_5 := t0_2 + t1_4
      t3_6 := convert(t2_5)
      t4_7 := convert(t3_6)
      t5_9 := convert(const_8)
      t6_10 := t4_7 + t5_9
      print "partial="%0d(t2_5)" widened=0x"%0x(t6_10)"\n"
      return

