module {
  hw.module @main(in %clk: i1, in %rst: i1) {
    %c_init_varargs = hw.constant 0 : i32
    %varargs = sv.reg : !hw.inout<i32>
    sv.initial {
      sv.bpassign %varargs, %c_init_varargs : i32
    }
    %c0 = hw.constant 42 : i32
    %state_const1 = hw.constant 0 : i1
    %state_const2 = hw.constant 1 : i1
    %state_reg3 = sv.reg : !hw.inout<i1>
    sv.initial {
      sv.bpassign %state_reg3, %state_const1 : i1
    }
    %state4 = sv.read_inout %state_reg3 : !hw.inout<i1>
    %print_reg5 = sv.reg : !hw.inout<i32>
    %print_zero6 = hw.constant 0 : i32
    sv.initial {
      sv.bpassign %print_reg5, %print_zero6 : i32
    }
    %stdout_fd7 = hw.constant 2147483649 : i32
    sv.always posedge %clk {
      sv.if %rst {
        sv.passign %state_reg3, %state_const1 : i1
      } else {
        sv.case %state4 : i1
        case b0: {
          sv.bpassign %print_reg5, %c0 : i32
          %print_val8 = sv.read_inout %print_reg5 : !hw.inout<i32>
          sv.fwrite %stdout_fd7, "x=%0d\n"(%print_val8) : i32
          sv.passign %state_reg3, %state_const2 : i1
        }
        case b1: {
          sv.passign %state_reg3, %state4 : i1
        }
        default: {
          sv.passign %state_reg3, %state4 : i1
        }
      }
    }
    hw.output
  }
}
