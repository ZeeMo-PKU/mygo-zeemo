module main(
  input clk,
        rst
);

  reg signed [31:0] varargs;
  initial
    varargs = 32'h0;
  reg  [2:0]  state_reg7;
  initial
    state_reg7 = 3'h0;
  reg signed [31:0] print_reg9;
  initial
    print_reg9 = 32'h0;
  reg signed [31:0] print_reg11;
  initial
    print_reg11 = 32'h0;
  reg signed [31:0] print_reg13;
  initial
    print_reg13 = 32'h0;
  reg signed [31:0] print_reg15;
  initial
    print_reg15 = 32'h0;
  reg signed [31:0] print_reg17;
  initial
    print_reg17 = 32'h0;
  reg signed [31:0] print_reg19;
  initial
    print_reg19 = 32'h0;
  wire        _GEN = 32'shA > 32'sh3;
  wire [31:0] _GEN_0 = 32'h3 - 32'hA;
  wire [31:0] _GEN_1 = 32'hA - 32'h3;
  always @(posedge clk) begin
    if (rst)
      state_reg7 <= 3'h0;
    else begin
      case (state_reg7)
        3'b000: begin
          if (_GEN)
            state_reg7 <= 3'h2;
          else
            state_reg7 <= 3'h1;
        end
        3'b001: begin
          print_reg9 = _GEN_0;
          print_reg11 = 32'hA;
          print_reg13 = 32'h3;
          $write("branch y>=x delta=%0d (x=%0d y=%0d)\n", print_reg9,
                  print_reg11, print_reg13);
          state_reg7 <= 3'h3;
        end
        3'b010: begin
          print_reg15 = _GEN_1;
          print_reg17 = 32'hA;
          print_reg19 = 32'h3;
          $write("branch x>y delta=%0d (x=%0d y=%0d)\n", print_reg15,
                  print_reg17, print_reg19);
          state_reg7 <= 3'h3;
        end
        3'b011:
          state_reg7 <= 3'h4;
        3'b100:
          state_reg7 <= state_reg7;
        default:
          state_reg7 <= state_reg7;
      endcase
    end
  end // always @(posedge)
endmodule

