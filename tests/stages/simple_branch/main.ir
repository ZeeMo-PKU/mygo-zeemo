module main
  ports:
    in  clk 1bu
    in  rst 1bu
  signals:
    const_0  const 1bu = true
    const_1  const 32bs = 10
    const_10 const 32bs = 0
    const_11 const 32bs = 0
    const_12 const 32bs = 0
    const_2  const 32bs = 3
    const_5  const 32bs = 0
    const_6  const 32bs = 0
    const_7  const 32bs = 0
    t0_3     wire  1bu
    t11_8    wire  32bs
    t13_9    wire  32bs
    t1_4     wire  32bs
    varargs  reg   32bs
  process 0 main (stage=0, sequential)
    block entry
      t0_3 := cmp(const_1 >s const_2)
      br t0_3 ? if.then : if.else
    block if.else
      t13_9 := const_2 - const_1
      print "branch y>=x delta="%0d(t13_9)" (x="%0d(const_1)" y="%0d(const_2)")\n"
      jump if.done
    block if.then
      t1_4 := const_1 - const_2
      print "branch x>y delta="%0d(t1_4)" (x="%0d(const_1)" y="%0d(const_2)")\n"
      jump if.done
    block if.done
      t11_8 := mux(t0_3 ? t1_4 : t13_9)
      return

