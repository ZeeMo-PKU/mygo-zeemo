module {
  hw.module @main(in %clk: i1, in %rst: i1) {
    %c_init_varargs = hw.constant 0 : i32
    %varargs = sv.reg : !hw.inout<i32>
    sv.initial {
      sv.bpassign %varargs, %c_init_varargs : i32
    }
    %c0 = hw.constant 10 : i32
    %c1 = hw.constant 3 : i32
    %state_const2 = hw.constant 0 : i3
    %state_const3 = hw.constant 1 : i3
    %state_const4 = hw.constant 2 : i3
    %state_const5 = hw.constant 3 : i3
    %state_const6 = hw.constant 4 : i3
    %state_reg7 = sv.reg : !hw.inout<i3>
    sv.initial {
      sv.bpassign %state_reg7, %state_const2 : i3
    }
    %state8 = sv.read_inout %state_reg7 : !hw.inout<i3>
    %print_reg9 = sv.reg : !hw.inout<i32>
    %print_zero10 = hw.constant 0 : i32
    sv.initial {
      sv.bpassign %print_reg9, %print_zero10 : i32
    }
    %print_reg11 = sv.reg : !hw.inout<i32>
    %print_zero12 = hw.constant 0 : i32
    sv.initial {
      sv.bpassign %print_reg11, %print_zero12 : i32
    }
    %print_reg13 = sv.reg : !hw.inout<i32>
    %print_zero14 = hw.constant 0 : i32
    sv.initial {
      sv.bpassign %print_reg13, %print_zero14 : i32
    }
    %print_reg15 = sv.reg : !hw.inout<i32>
    %print_zero16 = hw.constant 0 : i32
    sv.initial {
      sv.bpassign %print_reg15, %print_zero16 : i32
    }
    %print_reg17 = sv.reg : !hw.inout<i32>
    %print_zero18 = hw.constant 0 : i32
    sv.initial {
      sv.bpassign %print_reg17, %print_zero18 : i32
    }
    %print_reg19 = sv.reg : !hw.inout<i32>
    %print_zero20 = hw.constant 0 : i32
    sv.initial {
      sv.bpassign %print_reg19, %print_zero20 : i32
    }
    %v21 = comb.icmp sgt %c0, %c1 : i32
    %v22 = comb.sub %c1, %c0 : i32
    %v23 = comb.sub %c0, %c1 : i32
    %v24 = comb.mux %v21, %v23, %v22 : i32
    %stdout_fd25 = hw.constant 2147483649 : i32
    sv.always posedge %clk {
      sv.if %rst {
        sv.passign %state_reg7, %state_const2 : i3
      } else {
        sv.case %state8 : i3
        case b000: {
          sv.if %v21 {
            sv.passign %state_reg7, %state_const4 : i3
          } else {
            sv.passign %state_reg7, %state_const3 : i3
          }
        }
        case b001: {
          sv.bpassign %print_reg9, %v22 : i32
          %print_val26 = sv.read_inout %print_reg9 : !hw.inout<i32>
          sv.bpassign %print_reg11, %c0 : i32
          %print_val27 = sv.read_inout %print_reg11 : !hw.inout<i32>
          sv.bpassign %print_reg13, %c1 : i32
          %print_val28 = sv.read_inout %print_reg13 : !hw.inout<i32>
          sv.fwrite %stdout_fd25, "branch y>=x delta=%0d (x=%0d y=%0d)\n"(%print_val26, %print_val27, %print_val28) : i32, i32, i32
          sv.passign %state_reg7, %state_const5 : i3
        }
        case b010: {
          sv.bpassign %print_reg15, %v23 : i32
          %print_val29 = sv.read_inout %print_reg15 : !hw.inout<i32>
          sv.bpassign %print_reg17, %c0 : i32
          %print_val30 = sv.read_inout %print_reg17 : !hw.inout<i32>
          sv.bpassign %print_reg19, %c1 : i32
          %print_val31 = sv.read_inout %print_reg19 : !hw.inout<i32>
          sv.fwrite %stdout_fd25, "branch x>y delta=%0d (x=%0d y=%0d)\n"(%print_val29, %print_val30, %print_val31) : i32, i32, i32
          sv.passign %state_reg7, %state_const5 : i3
        }
        case b011: {
          sv.passign %state_reg7, %state_const6 : i3
        }
        case b100: {
          sv.passign %state_reg7, %state8 : i3
        }
        default: {
          sv.passign %state_reg7, %state8 : i3
        }
      }
    }
    hw.output
  }
}
