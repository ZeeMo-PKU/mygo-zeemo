    %chan_t4_one = hw.constant 1 : i1
    %chan_t4_rst_n = comb.xor %rst, %chan_t4_one : i1
    hw.instance "t4_fifo" @mygo_fifo_i1_d5(clk: %clk : i1, rst_n: %chan_t4_rst_n : i1, wr_en: %chan_t4_wvalid : !hw.inout<i1>, wr_data: %chan_t4_wdata : !hw.inout<i1>, full: %chan_t4_full : !hw.inout<i1>, almost_full: %chan_t4_almost_full : !hw.inout<i1>, rd_en: %chan_t4_rready : !hw.inout<i1>, rd_data: %chan_t4_rdata : !hw.inout<i1>, empty: %chan_t4_empty : !hw.inout<i1>, almost_empty: %chan_t4_almost_empty : !hw.inout<i1>) -> ()
    %chan_t4_full_val = sv.read_inout %chan_t4_full : !hw.inout<i1>
    %chan_t4_not_full = comb.xor %chan_t4_full_val, %chan_t4_one : i1
    %mp_valid0 = sv.read_inout %chan_t4_prod0_consumer0_wvalid : !hw.inout<i1>
    %mp_data1 = sv.read_inout %chan_t4_prod0_consumer0_wdata : !hw.inout<i1>
    %mp_valid2 = sv.read_inout %chan_t4_prod1_consumer1_wvalid : !hw.inout<i1>
    %mp_data3 = sv.read_inout %chan_t4_prod1_consumer1_wdata : !hw.inout<i1>
    %mp_no_prior4 = comb.xor %mp_valid0, %chan_t4_one : i1
    %mp_grant5 = comb.and %mp_valid2, %mp_no_prior4 : i1
    %mp_prior6 = comb.or %mp_valid0, %mp_valid2 : i1
    %mp_valid7 = sv.read_inout %chan_t4_prod2_router_wvalid : !hw.inout<i1>
    %mp_data8 = sv.read_inout %chan_t4_prod2_router_wdata : !hw.inout<i1>
    %mp_no_prior9 = comb.xor %mp_prior6, %chan_t4_one : i1
    %mp_grant10 = comb.and %mp_valid7, %mp_no_prior9 : i1
    %mp_prior11 = comb.or %mp_prior6, %mp_valid7 : i1
    %mp_valid12 = sv.read_inout %chan_t4_prod3_producer0_wvalid : !hw.inout<i1>
    %mp_data13 = sv.read_inout %chan_t4_prod3_producer0_wdata : !hw.inout<i1>
    %mp_no_prior14 = comb.xor %mp_prior11, %chan_t4_one : i1
    %mp_grant15 = comb.and %mp_valid12, %mp_no_prior14 : i1
    %mp_prior16 = comb.or %mp_prior11, %mp_valid12 : i1
    %mp_valid17 = sv.read_inout %chan_t4_prod4_producer1_wvalid : !hw.inout<i1>
    %mp_data18 = sv.read_inout %chan_t4_prod4_producer1_wdata : !hw.inout<i1>
    %mp_no_prior19 = comb.xor %mp_prior16, %chan_t4_one : i1
    %mp_grant20 = comb.and %mp_valid17, %mp_no_prior19 : i1
    %mp_prior21 = comb.or %mp_prior16, %mp_valid17 : i1
    %or22 = comb.or %mp_valid0, %mp_valid2 : i1
    %or23 = comb.or %or22, %mp_valid7 : i1
    %or24 = comb.or %or23, %mp_valid12 : i1
    %or25 = comb.or %or24, %mp_valid17 : i1
    sv.assign %chan_t4_wvalid, %or25 : i1
    %c_zero26 = hw.constant 0 : i1
    %mux27 = comb.mux %mp_grant20, %mp_data18, %c_zero26 : i1
    %mux28 = comb.mux %mp_grant15, %mp_data13, %mux27 : i1
    %mux29 = comb.mux %mp_grant10, %mp_data8, %mux28 : i1
    %mux30 = comb.mux %mp_grant5, %mp_data3, %mux29 : i1
    %mux31 = comb.mux %mp_valid0, %mp_data1, %mux30 : i1
    sv.assign %chan_t4_wdata, %mux31 : i1
    %mp_ready32 = comb.and %mp_valid0, %chan_t4_not_full : i1
    sv.assign %chan_t4_prod0_consumer0_wready, %mp_ready32 : i1
    %mp_ready33 = comb.and %mp_grant5, %chan_t4_not_full : i1
    sv.assign %chan_t4_prod1_consumer1_wready, %mp_ready33 : i1
    %mp_ready34 = comb.and %mp_grant10, %chan_t4_not_full : i1
    sv.assign %chan_t4_prod2_router_wready, %mp_ready34 : i1
    %mp_ready35 = comb.and %mp_grant15, %chan_t4_not_full : i1
    sv.assign %chan_t4_prod3_producer0_wready, %mp_ready35 : i1
    %mp_ready36 = comb.and %mp_grant20, %chan_t4_not_full : i1
    sv.assign %chan_t4_prod4_producer1_wready, %mp_ready36 : i1
    %chan_t4_empty_val = sv.read_inout %chan_t4_empty : !hw.inout<i1>
    %chan_t4_not_empty = comb.xor %chan_t4_empty_val, %chan_t4_one : i1
    sv.assign %chan_t4_rvalid, %chan_t4_not_empty : i1
    %c_init_varargs = hw.constant 0 : i32
    %varargs = sv.reg : !hw.inout<i32>
    sv.initial {
      sv.bpassign %varargs, %c_init_varargs : i32
    }
    %c37 = hw.constant 0 : i32
    %c38 = hw.constant 5 : i32
    %c39 = hw.constant 1 : i32
    %c40 = hw.constant 4 : i32
    %state_const41 = hw.constant 0 : i3
    %state_const42 = hw.constant 1 : i3
    %state_const43 = hw.constant 2 : i3
    %state_const44 = hw.constant 3 : i3
    %state_const45 = hw.constant 4 : i3
    %state_const46 = hw.constant 5 : i3
    %state_const47 = hw.constant 6 : i3
    %state_reg48 = sv.reg : !hw.inout<i3>
    sv.initial {
      sv.bpassign %state_reg48, %state_const41 : i3
    }
    %state49 = sv.read_inout %state_reg48 : !hw.inout<i3>
    %recv_reg50 = sv.reg : !hw.inout<i1>
    %v51 = sv.read_inout %recv_reg50 : !hw.inout<i1>
    %print_reg52 = sv.reg : !hw.inout<i32>
    %print_zero53 = hw.constant 0 : i32
    sv.initial {
      sv.bpassign %print_reg52, %print_zero53 : i32
    }
    // spawn consumer0 stage=1 parent_stage=0
    // spawn consumer1 stage=2 parent_stage=0
    // spawn router stage=3 parent_stage=0
    // spawn producer0 stage=4 parent_stage=0
    // spawn producer1 stage=5 parent_stage=0
    %phi_reg54 = sv.reg : !hw.inout<i32>
    %v55 = sv.read_inout %phi_reg54 : !hw.inout<i32>
    %v56 = comb.icmp slt %v55, %c38 : i32
    %v57 = comb.add %v55, %c39 : i32
    %stdout_fd58 = hw.constant 2147483649 : i32
    %state_is59 = comb.icmp eq %state49, %state_const45 : i3
    sv.assign %chan_t4_rready, %state_is59 : i1
    %recv_valid60 = sv.read_inout %chan_t4_rvalid : !hw.inout<i1>
    %recv_data61 = sv.read_inout %chan_t4_rdata : !hw.inout<i1>
    sv.always posedge %clk {
      sv.if %rst {
        sv.passign %state_reg48, %state_const41 : i3
      } else {
        sv.case %state49 : i3
        case b000: {
          sv.passign %state_reg48, %state_const42 : i3
          sv.passign %phi_reg54, %c37 : i32
        }
        case b001: {
          sv.if %v56 {
            sv.passign %state_reg48, %state_const44 : i3
          } else {
            sv.passign %state_reg48, %state_const43 : i3
          }
        }
        case b010: {
          sv.bpassign %print_reg52, %c40 : i32
          %print_val62 = sv.read_inout %print_reg52 : !hw.inout<i32>
          sv.fwrite %stdout_fd58, "router complete packets=%0d\n"(%print_val62) : i32
          sv.passign %state_reg48, %state_const47 : i3
        }
        case b011: {
          sv.passign %state_reg48, %state_const45 : i3
        }
        case b100: {
          sv.if %recv_valid60 {
            sv.passign %recv_reg50, %recv_data61 : i1
            sv.passign %state_reg48, %state_const46 : i3
          } else {
            sv.passign %state_reg48, %state49 : i3
          }
        }
        case b101: {
          sv.passign %state_reg48, %state_const42 : i3
          sv.passign %phi_reg54, %v57 : i32
        }
        case b110: {
          sv.passign %state_reg48, %state49 : i3
        }
        default: {
          sv.passign %state_reg48, %state49 : i3
        }
      }
    }
