module main__proc_producer0(
  input        clk,
               rst,
  inout [31:0] chan_t0_wdata,
  inout        chan_t0_wvalid,
               chan_t0_wready,
               chan_t4_wdata,
               chan_t4_wvalid,
               chan_t4_wready
);

  reg  [3:0]  state_reg185;
  initial
    state_reg185 = 4'h0;
  reg  [31:0] print_reg187;
  initial
    print_reg187 = 32'h0;
  reg  [31:0] print_reg189;
  initial
    print_reg189 = 32'h0;
  reg  [31:0] print_reg191;
  initial
    print_reg191 = 32'h0;
  reg  [31:0] phi_reg193;
  wire [31:0] _GEN = phi_reg193 & 32'h1;
  wire        _GEN_0 = state_reg185 == 4'h3;
  assign chan_t0_wvalid = state_reg185 == 4'h6;
  assign chan_t0_wdata = chan_t0_wvalid ? _GEN << 32'h10 | phi_reg193 & 32'hFFFF : 32'h0;
  assign chan_t4_wvalid = _GEN_0;
  assign chan_t4_wdata = _GEN_0;
  always @(posedge clk) begin
    if (rst)
      state_reg185 <= 4'h0;
    else begin
      case (state_reg185)
        4'b0000: begin
          state_reg185 <= 4'h1;
          phi_reg193 <= 32'h0;
        end
        4'b0001: begin
          if (phi_reg193 < 32'h4)
            state_reg185 <= 4'h5;
          else
            state_reg185 <= 4'h2;
        end
        4'b0010:
          state_reg185 <= 4'h3;
        4'b0011: begin
          if (chan_t4_wready)
            state_reg185 <= 4'h4;
          else
            state_reg185 <= state_reg185;
        end
        4'b0100:
          state_reg185 <= 4'h8;
        4'b0101:
          state_reg185 <= 4'h6;
        4'b0110: begin
          if (chan_t0_wready)
            state_reg185 <= 4'h7;
          else
            state_reg185 <= state_reg185;
        end
        4'b0111: begin
          print_reg187 = 32'h0;
          print_reg189 = _GEN;
          print_reg191 = phi_reg193;
          $write("producer %0d sent dest=%0d payload=%0d\n", print_reg187,
                  print_reg189, print_reg191);
          state_reg185 <= 4'h1;
          phi_reg193 <= phi_reg193 + 32'h1;
        end
        4'b1000:
          state_reg185 <= state_reg185;
        default:
          state_reg185 <= state_reg185;
      endcase
    end
  end // always @(posedge)
endmodule

module main__proc_producer1(
  input        clk,
               rst,
  inout [31:0] chan_t1_wdata,
  inout        chan_t1_wvalid,
               chan_t1_wready,
               chan_t4_wdata,
               chan_t4_wvalid,
               chan_t4_wready
);

  reg  [3:0]  state_reg234;
  initial
    state_reg234 = 4'h0;
  reg  [31:0] print_reg236;
  initial
    print_reg236 = 32'h0;
  reg  [31:0] print_reg238;
  initial
    print_reg238 = 32'h0;
  reg  [31:0] print_reg240;
  initial
    print_reg240 = 32'h0;
  reg  [31:0] phi_reg242;
  wire [31:0] _GEN = phi_reg242 + 32'h1 & 32'h1;
  wire [31:0] _GEN_0 = phi_reg242 + 32'hA;
  wire        _GEN_1 = state_reg234 == 4'h3;
  assign chan_t1_wvalid = state_reg234 == 4'h6;
  assign chan_t1_wdata =
    chan_t1_wvalid ? _GEN << 32'h10 | 32'h1000000 | _GEN_0 & 32'hFFFF : 32'h0;
  assign chan_t4_wvalid = _GEN_1;
  assign chan_t4_wdata = _GEN_1;
  always @(posedge clk) begin
    if (rst)
      state_reg234 <= 4'h0;
    else begin
      case (state_reg234)
        4'b0000: begin
          state_reg234 <= 4'h1;
          phi_reg242 <= 32'h0;
        end
        4'b0001: begin
          if (phi_reg242 < 32'h4)
            state_reg234 <= 4'h5;
          else
            state_reg234 <= 4'h2;
        end
        4'b0010:
          state_reg234 <= 4'h3;
        4'b0011: begin
          if (chan_t4_wready)
            state_reg234 <= 4'h4;
          else
            state_reg234 <= state_reg234;
        end
        4'b0100:
          state_reg234 <= 4'h8;
        4'b0101:
          state_reg234 <= 4'h6;
        4'b0110: begin
          if (chan_t1_wready)
            state_reg234 <= 4'h7;
          else
            state_reg234 <= state_reg234;
        end
        4'b0111: begin
          print_reg236 = 32'h1;
          print_reg238 = _GEN;
          print_reg240 = _GEN_0;
          $write("producer %0d sent dest=%0d payload=%0d\n", print_reg236,
                  print_reg238, print_reg240);
          state_reg234 <= 4'h1;
          phi_reg242 <= phi_reg242 + 32'h1;
        end
        4'b1000:
          state_reg234 <= state_reg234;
        default:
          state_reg234 <= state_reg234;
      endcase
    end
  end // always @(posedge)
endmodule

module main__proc_router(
  input        clk,
               rst,
  inout [31:0] chan_t0_rdata,
  inout        chan_t0_rvalid,
               chan_t0_rready,
  inout [31:0] chan_t1_rdata,
  inout        chan_t1_rvalid,
               chan_t1_rready,
  inout [31:0] chan_t2_wdata,
  inout        chan_t2_wvalid,
               chan_t2_wready,
  inout [31:0] chan_t3_wdata,
  inout        chan_t3_wvalid,
               chan_t3_wready,
               chan_t4_wdata,
               chan_t4_wvalid,
               chan_t4_wready
);

  reg  [4:0]  state_reg302;
  initial
    state_reg302 = 5'h0;
  reg  [31:0] recv_reg304;
  reg  [31:0] recv_reg306;
  reg  [31:0] phi_reg308;
  wire        _GEN = state_reg302 == 5'h3;
  wire        _GEN_0 = state_reg302 == 5'h9;
  wire        _GEN_1 = state_reg302 == 5'hC;
  wire        _GEN_2 = state_reg302 == 5'h12;
  wire        _GEN_3 = state_reg302 == 5'h15;
  assign chan_t2_wvalid = _GEN_1 | _GEN_3;
  assign chan_t2_wdata = _GEN_1 ? recv_reg304 : _GEN_3 ? recv_reg306 : 32'h0;
  assign chan_t3_wvalid = _GEN_0 | _GEN_2;
  assign chan_t3_wdata = _GEN_0 ? recv_reg304 : _GEN_2 ? recv_reg306 : 32'h0;
  assign chan_t4_wvalid = _GEN;
  assign chan_t4_wdata = _GEN;
  assign chan_t0_rready = state_reg302 == 5'h6;
  assign chan_t1_rready = state_reg302 == 5'hF;
  always @(posedge clk) begin
    if (rst)
      state_reg302 <= 5'h0;
    else begin
      case (state_reg302)
        5'b00000: begin
          state_reg302 <= 5'h1;
          phi_reg308 <= 32'h0;
        end
        5'b00001: begin
          if (phi_reg308 < 32'h4)
            state_reg302 <= 5'h5;
          else
            state_reg302 <= 5'h2;
        end
        5'b00010:
          state_reg302 <= 5'h3;
        5'b00011: begin
          if (chan_t4_wready)
            state_reg302 <= 5'h4;
          else
            state_reg302 <= state_reg302;
        end
        5'b00100:
          state_reg302 <= 5'h18;
        5'b00101:
          state_reg302 <= 5'h6;
        5'b00110: begin
          if (chan_t0_rvalid) begin
            recv_reg304 <= chan_t0_rdata;
            state_reg302 <= 5'h7;
          end
          else
            state_reg302 <= state_reg302;
        end
        5'b00111: begin
          if ((recv_reg304 >> 32'h10 & 32'hFF & 32'h1) == 32'h0)
            state_reg302 <= 5'hB;
          else
            state_reg302 <= 5'h8;
        end
        5'b01000:
          state_reg302 <= 5'h9;
        5'b01001: begin
          if (chan_t3_wready)
            state_reg302 <= 5'hA;
          else
            state_reg302 <= state_reg302;
        end
        5'b01010:
          state_reg302 <= 5'hE;
        5'b01011:
          state_reg302 <= 5'hC;
        5'b01100: begin
          if (chan_t2_wready)
            state_reg302 <= 5'hD;
          else
            state_reg302 <= state_reg302;
        end
        5'b01101:
          state_reg302 <= 5'hE;
        5'b01110:
          state_reg302 <= 5'hF;
        5'b01111: begin
          if (chan_t1_rvalid) begin
            recv_reg306 <= chan_t1_rdata;
            state_reg302 <= 5'h10;
          end
          else
            state_reg302 <= state_reg302;
        end
        5'b10000: begin
          if ((recv_reg306 >> 32'h10 & 32'hFF & 32'h1) == 32'h0)
            state_reg302 <= 5'h14;
          else
            state_reg302 <= 5'h11;
        end
        5'b10001:
          state_reg302 <= 5'h12;
        5'b10010: begin
          if (chan_t3_wready)
            state_reg302 <= 5'h13;
          else
            state_reg302 <= state_reg302;
        end
        5'b10011:
          state_reg302 <= 5'h17;
        5'b10100:
          state_reg302 <= 5'h15;
        5'b10101: begin
          if (chan_t2_wready)
            state_reg302 <= 5'h16;
          else
            state_reg302 <= state_reg302;
        end
        5'b10110:
          state_reg302 <= 5'h17;
        5'b10111: begin
          state_reg302 <= 5'h1;
          phi_reg308 <= phi_reg308 + 32'h1;
        end
        5'b11000:
          state_reg302 <= state_reg302;
        default:
          state_reg302 <= state_reg302;
      endcase
    end
  end // always @(posedge)
endmodule


module mygo_fifo #(
  parameter integer DATA_WIDTH = 32,
  parameter integer DEPTH = 1,
  parameter integer ADDR_WIDTH = 1,
  parameter integer COUNT_WIDTH = 1,
  parameter integer LAST_PTR_VALUE = 0,
  parameter integer DEPTH_COUNT_VALUE = 1,
  parameter integer ALMOST_FULL_LEVEL = 1,
  parameter integer ALMOST_EMPTY_LEVEL = 0,
  parameter integer ALMOST_FULL_COUNT_VALUE = 1,
  parameter integer ALMOST_EMPTY_COUNT_VALUE = 0,
  parameter bit USE_REGISTERED_READ = 1'b0,
  parameter bit ALMOST_EMPTY_USES_EMPTY = 1'b1,
  parameter bit ASYNC_RESET = 1'b0
) (
  input  wire                   clk,
  input  wire                   rst_n,
  input  wire                   wr_en,
  input  wire [DATA_WIDTH-1:0]  wr_data,
  output wire                   full,
  output wire                   almost_full,
  input  wire                   rd_en,
  output wire [DATA_WIDTH-1:0]  rd_data,
  output wire                   empty,
  output wire                   almost_empty
);

  localparam [ADDR_WIDTH-1:0] LAST_PTR = ADDR_WIDTH'(LAST_PTR_VALUE);
  localparam [COUNT_WIDTH-1:0] DEPTH_COUNT = COUNT_WIDTH'(DEPTH_COUNT_VALUE);
  localparam [COUNT_WIDTH-1:0] ALMOST_FULL_COUNT = COUNT_WIDTH'(ALMOST_FULL_COUNT_VALUE);
  localparam [COUNT_WIDTH-1:0] ALMOST_EMPTY_COUNT = COUNT_WIDTH'(ALMOST_EMPTY_COUNT_VALUE);

  reg [DATA_WIDTH-1:0] mem [0:DEPTH-1];
  reg [ADDR_WIDTH-1:0] wr_ptr;
  reg [ADDR_WIDTH-1:0] rd_ptr;
  reg [COUNT_WIDTH-1:0] count;

  wire wr_fire = wr_en && !full;
  wire rd_fire = rd_en && !empty;
  wire [ADDR_WIDTH-1:0] wr_ptr_next = (wr_ptr == LAST_PTR) ? {ADDR_WIDTH{1'b0}} : (wr_ptr + 1'b1);
  wire [ADDR_WIDTH-1:0] rd_ptr_next = (rd_ptr == LAST_PTR) ? {ADDR_WIDTH{1'b0}} : (rd_ptr + 1'b1);

  assign full = (count == DEPTH_COUNT);
  assign empty = (count == {COUNT_WIDTH{1'b0}});
  assign almost_full = (count >= ALMOST_FULL_COUNT);
  assign almost_empty = (ALMOST_EMPTY_USES_EMPTY != 1'b0) ? empty : (count <= ALMOST_EMPTY_COUNT);

  generate
    if (USE_REGISTERED_READ != 1'b0) begin : gen_registered_read
      reg [DATA_WIDTH-1:0] rd_data_reg;
      assign rd_data = empty ? {DATA_WIDTH{1'b0}} : rd_data_reg;

      if (ASYNC_RESET != 1'b0) begin : gen_async_reset
        always @(posedge clk or negedge rst_n) begin
          if (!rst_n) begin
            wr_ptr <= {ADDR_WIDTH{1'b0}};
            rd_ptr <= {ADDR_WIDTH{1'b0}};
            count <= {COUNT_WIDTH{1'b0}};
            rd_data_reg <= {DATA_WIDTH{1'b0}};
          end else begin
            if (wr_fire) begin
              mem[wr_ptr] <= wr_data;
              wr_ptr <= wr_ptr_next;
            end
            if (rd_fire) begin
              rd_ptr <= rd_ptr_next;
            end
            case ({wr_fire, rd_fire})
              2'b10: count <= count + 1'b1;
              2'b01: count <= count - 1'b1;
              default: count <= count;
            endcase
            if (empty && wr_fire) begin
              rd_data_reg <= wr_data;
            end else if (rd_fire) begin
              if (count > 1) begin
                rd_data_reg <= mem[rd_ptr_next];
              end else if (wr_fire) begin
                rd_data_reg <= wr_data;
              end else begin
                rd_data_reg <= {DATA_WIDTH{1'b0}};
              end
            end else if (!empty) begin
              rd_data_reg <= mem[rd_ptr];
            end
          end
        end
      end else begin : gen_sync_reset
        always @(posedge clk) begin
          if (!rst_n) begin
            wr_ptr <= {ADDR_WIDTH{1'b0}};
            rd_ptr <= {ADDR_WIDTH{1'b0}};
            count <= {COUNT_WIDTH{1'b0}};
            rd_data_reg <= {DATA_WIDTH{1'b0}};
          end else begin
            if (wr_fire) begin
              mem[wr_ptr] <= wr_data;
              wr_ptr <= wr_ptr_next;
            end
            if (rd_fire) begin
              rd_ptr <= rd_ptr_next;
            end
            case ({wr_fire, rd_fire})
              2'b10: count <= count + 1'b1;
              2'b01: count <= count - 1'b1;
              default: count <= count;
            endcase
            if (empty && wr_fire) begin
              rd_data_reg <= wr_data;
            end else if (rd_fire) begin
              if (count > 1) begin
                rd_data_reg <= mem[rd_ptr_next];
              end else if (wr_fire) begin
                rd_data_reg <= wr_data;
              end else begin
                rd_data_reg <= {DATA_WIDTH{1'b0}};
              end
            end else if (!empty) begin
              rd_data_reg <= mem[rd_ptr];
            end
          end
        end
      end
    end else begin : gen_direct_read
      assign rd_data = empty ? {DATA_WIDTH{1'b0}} : mem[rd_ptr];

      if (ASYNC_RESET != 1'b0) begin : gen_async_reset
        always @(posedge clk or negedge rst_n) begin
          if (!rst_n) begin
            wr_ptr <= {ADDR_WIDTH{1'b0}};
            rd_ptr <= {ADDR_WIDTH{1'b0}};
            count <= {COUNT_WIDTH{1'b0}};
          end else begin
            if (wr_fire) begin
              mem[wr_ptr] <= wr_data;
              wr_ptr <= wr_ptr_next;
            end
            if (rd_fire) begin
              rd_ptr <= rd_ptr_next;
            end
            case ({wr_fire, rd_fire})
              2'b10: count <= count + 1'b1;
              2'b01: count <= count - 1'b1;
              default: count <= count;
            endcase
          end
        end
      end else begin : gen_sync_reset
        always @(posedge clk) begin
          if (!rst_n) begin
            wr_ptr <= {ADDR_WIDTH{1'b0}};
            rd_ptr <= {ADDR_WIDTH{1'b0}};
            count <= {COUNT_WIDTH{1'b0}};
          end else begin
            if (wr_fire) begin
              mem[wr_ptr] <= wr_data;
              wr_ptr <= wr_ptr_next;
            end
            if (rd_fire) begin
              rd_ptr <= rd_ptr_next;
            end
            case ({wr_fire, rd_fire})
              2'b10: count <= count + 1'b1;
              2'b01: count <= count - 1'b1;
              default: count <= count;
            endcase
          end
        end
      end
    end
  endgenerate
endmodule

// mygo autogenerated loop FSM fallback modules
module main__proc_main__loop0_fsm(
  input clk,
        rst,
        check_cond,
        body_done,
        update_done,
  output reg [1:0] state,
  output     active,
             done,
             body_enable,
             update_enable,
             state_check,
             state_body,
             state_update,
             state_exit
);

  // Derived from IR loop condition signal: t19_120
  localparam [1:0] STATE_CHECK  = 2'd0;
  localparam [1:0] STATE_BODY   = 2'd1;
  localparam [1:0] STATE_UPDATE = 2'd2;
  localparam [1:0] STATE_EXIT   = 2'd3;

  // Predecoded state predicates keep control fanout shallow for improved timing closure.
  wire state_is_check = (state == STATE_CHECK);
  wire state_is_body = (state == STATE_BODY);
  wire state_is_update = (state == STATE_UPDATE);
  wire state_is_exit = (state == STATE_EXIT);

  assign state_check = state_is_check;
  assign state_body = state_is_body;
  assign state_update = state_is_update;
  assign state_exit = state_is_exit;
  assign body_enable = state_is_body;
  assign update_enable = state_is_update;
  assign active = ~state_is_exit;
  assign done = state_is_exit;

  // Compact binary state encoding minimizes register usage while keeping timing predictable.
  (* fsm_encoding = "sequential" *) reg [1:0] next_state;

  always @(*) begin
    // Default hold avoids unnecessary state toggles and shortens the transition logic cone.
    next_state = state;
    case (state)
      STATE_CHECK: begin
        if (check_cond)
          next_state = STATE_BODY;
        else
          next_state = STATE_EXIT;
      end
      STATE_BODY: begin
        if (body_done)
          next_state = STATE_UPDATE;
      end
      STATE_UPDATE: begin
        if (update_done)
          next_state = STATE_CHECK;
      end
      STATE_EXIT: begin
        next_state = STATE_EXIT;
      end
      default:
        next_state = STATE_CHECK;
    endcase
  end

  always @(posedge clk) begin
    if (rst)
      state <= STATE_CHECK;
    else
      state <= next_state;
  end
endmodule
