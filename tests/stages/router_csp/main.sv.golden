module main__proc_consumer0(
  input        clk,
               rst,
  inout [31:0] chan_t2_rdata,
  inout        chan_t2_rvalid,
               chan_t2_rready,
               chan_t4_wdata,
               chan_t4_wvalid,
               chan_t4_wready
);

  reg  [3:0]  state_reg82;
  initial
    state_reg82 = 4'h0;
  reg  [31:0] recv_reg84;
  reg  [31:0] print_reg86;
  initial
    print_reg86 = 32'h0;
  reg  [31:0] print_reg88;
  initial
    print_reg88 = 32'h0;
  reg  [31:0] print_reg90;
  initial
    print_reg90 = 32'h0;
  reg  [31:0] print_reg92;
  initial
    print_reg92 = 32'h0;
  reg  [31:0] phi_reg94;
  wire        _GEN = state_reg82 == 4'h3;
  assign chan_t4_wvalid = _GEN;
  assign chan_t4_wdata = _GEN;
  assign chan_t2_rready = state_reg82 == 4'h6;
  always @(posedge clk) begin
    if (rst)
      state_reg82 <= 4'h0;
    else begin
      case (state_reg82)
        4'b0000: begin
          state_reg82 <= 4'h1;
          phi_reg94 <= 32'h0;
        end
        4'b0001: begin
          if (phi_reg94 < 32'h4)
            state_reg82 <= 4'h5;
          else
            state_reg82 <= 4'h2;
        end
        4'b0010:
          state_reg82 <= 4'h3;
        4'b0011: begin
          if (chan_t4_wready)
            state_reg82 <= 4'h4;
          else
            state_reg82 <= state_reg82;
        end
        4'b0100:
          state_reg82 <= 4'h8;
        4'b0101:
          state_reg82 <= 4'h6;
        4'b0110: begin
          if (chan_t2_rvalid) begin
            recv_reg84 <= chan_t2_rdata;
            state_reg82 <= 4'h7;
          end
          else
            state_reg82 <= state_reg82;
        end
        4'b0111: begin
          print_reg86 = 32'h0;
          print_reg88 = recv_reg84 >> 32'h18 & 32'hFF;
          print_reg90 = recv_reg84 >> 32'h10 & 32'hFF;
          print_reg92 = recv_reg84 & 32'hFFFF;
          $write("consumer %0d got src=%0d dest=%0d payload=%0d\n",
                  print_reg86, print_reg88, print_reg90, print_reg92);
          state_reg82 <= 4'h1;
          phi_reg94 <= phi_reg94 + 32'h1;
        end
        4'b1000:
          state_reg82 <= state_reg82;
        default:
          state_reg82 <= state_reg82;
      endcase
    end
  end // always @(posedge)
endmodule

