  mygo_fifo #(.DATA_WIDTH(1), .DEPTH(5), .ADDR_WIDTH(3), .COUNT_WIDTH(3), .LAST_PTR_VALUE(4), .DEPTH_COUNT_VALUE(5), .ALMOST_FULL_LEVEL(4), .ALMOST_EMPTY_LEVEL(1), .ALMOST_FULL_COUNT_VALUE(4), .ALMOST_EMPTY_COUNT_VALUE(1), .USE_REGISTERED_READ(0), .ALMOST_EMPTY_USES_EMPTY(0), .ASYNC_RESET(0)) t4_fifo (
    .clk          (clk),
    .rst_n        (~rst),
    .wr_en        (chan_t4_wvalid),
    .wr_data      (chan_t4_wdata),
    .full         (chan_t4_full),
    .almost_full  (chan_t4_almost_full),
    .rd_en        (chan_t4_rready),
    .rd_data      (chan_t4_rdata),
    .empty        (chan_t4_empty),
    .almost_empty (chan_t4_almost_empty)
  );
  wire        _GEN = ~chan_t4_full;
  wire        _GEN_0 = chan_t4_prod1_consumer1_wvalid & ~chan_t4_prod0_consumer0_wvalid;
  wire        _GEN_1 = chan_t4_prod0_consumer0_wvalid | chan_t4_prod1_consumer1_wvalid;
  wire        _GEN_2 = chan_t4_prod2_router_wvalid & ~_GEN_1;
  wire        _GEN_3 = _GEN_1 | chan_t4_prod2_router_wvalid;
  wire        _GEN_4 = chan_t4_prod3_producer0_wvalid & ~_GEN_3;
  wire        _GEN_5 = _GEN_3 | chan_t4_prod3_producer0_wvalid;
  wire        _GEN_6 = chan_t4_prod4_producer1_wvalid & ~_GEN_5;
  assign chan_t4_wvalid =
    chan_t4_prod0_consumer0_wvalid | chan_t4_prod1_consumer1_wvalid
    | chan_t4_prod2_router_wvalid | chan_t4_prod3_producer0_wvalid
    | chan_t4_prod4_producer1_wvalid;
  assign chan_t4_wdata =
    chan_t4_prod0_consumer0_wvalid
      ? chan_t4_prod0_consumer0_wdata
      : _GEN_0
          ? chan_t4_prod1_consumer1_wdata
          : _GEN_2
              ? chan_t4_prod2_router_wdata
              : _GEN_4
                  ? chan_t4_prod3_producer0_wdata
                  : _GEN_6 ? chan_t4_prod4_producer1_wdata : 1'h0;
  assign chan_t4_prod0_consumer0_wready = chan_t4_prod0_consumer0_wvalid & _GEN;
  assign chan_t4_prod1_consumer1_wready = _GEN_0 & _GEN;
  assign chan_t4_prod2_router_wready = _GEN_2 & _GEN;
  assign chan_t4_prod3_producer0_wready = _GEN_4 & _GEN;
  assign chan_t4_prod4_producer1_wready = _GEN_6 & _GEN;
  assign chan_t4_rvalid = ~chan_t4_empty;
  reg signed [31:0] varargs;
  initial
    varargs = 32'h0;
  reg  [2:0]  state_reg48;
  initial
    state_reg48 = 3'h0;
  reg         recv_reg50;
  reg signed [31:0] print_reg52;
  initial
    print_reg52 = 32'h0;
  reg  [31:0] phi_reg54;
  assign chan_t4_rready = state_reg48 == 3'h4;
  always @(posedge clk) begin
    if (rst)
      state_reg48 <= 3'h0;
    else begin
      case (state_reg48)
        3'b000: begin
          state_reg48 <= 3'h1;
          phi_reg54 <= 32'h0;
        end
        3'b001: begin
          if ($signed(phi_reg54) < 32'sh5)
            state_reg48 <= 3'h3;
          else
            state_reg48 <= 3'h2;
        end
        3'b010: begin
          print_reg52 = 32'h4;
          $write("router complete packets=%0d\n", print_reg52);
          state_reg48 <= 3'h6;
        end
        3'b011:
          state_reg48 <= 3'h4;
        3'b100: begin
          if (chan_t4_rvalid) begin
            recv_reg50 <= chan_t4_rdata;
            state_reg48 <= 3'h5;
          end
          else
            state_reg48 <= state_reg48;
        end
        3'b101: begin
          state_reg48 <= 3'h1;
          phi_reg54 <= phi_reg54 + 32'h1;
        end
        3'b110:
          state_reg48 <= state_reg48;
        default:
          state_reg48 <= state_reg48;
      endcase
    end
  end // always @(posedge)
  main__proc_consumer0 consumer0_inst0 (
