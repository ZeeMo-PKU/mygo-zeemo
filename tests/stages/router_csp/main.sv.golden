  mygo_fifo #(.DATA_WIDTH(32), .DEPTH(2), .ADDR_WIDTH(1), .COUNT_WIDTH(2), .LAST_PTR_VALUE(1), .DEPTH_COUNT_VALUE(2), .ALMOST_FULL_LEVEL(1), .ALMOST_EMPTY_LEVEL(1), .ALMOST_FULL_COUNT_VALUE(1), .ALMOST_EMPTY_COUNT_VALUE(1), .USE_REGISTERED_READ(0), .ALMOST_EMPTY_USES_EMPTY(0), .ASYNC_RESET(0)) t0_fifo (
    .clk          (clk),
