module main();
  reg signed [255:0] input_0;
  initial
    input_0 = 256'h0;
  reg  [31:0]  input_0_0;
  initial
    input_0_0 = 32'h0;
  reg signed [31:0]  input_1;
  initial
    input_1 = 32'h0;
  reg signed [31:0]  input_2;
  initial
    input_2 = 32'h0;
  reg signed [31:0]  input_3;
  initial
    input_3 = 32'h0;
  reg signed [31:0]  input_4;
  initial
    input_4 = 32'h0;
  reg signed [31:0]  input_5;
  initial
    input_5 = 32'h0;
  reg signed [31:0]  input_6;
  initial
    input_6 = 32'h0;
  reg signed [31:0]  input_7;
  initial
    input_7 = 32'h0;
  wire [255:0] _GEN =
    {input_7, input_6, input_5, input_4, input_3, input_2, input_1, input_0_0};
  wire [255:0] _GEN_0 = _GEN >> 256'h0 * 256'h20 & 256'hFFFFFFFF;
  wire [255:0] _GEN_1 = _GEN >> 256'h0 * 256'h20 & 256'hFFFFFFFF;
  wire [255:0] _GEN_2 = _GEN >> 256'h0 * 256'h20 & 256'hFFFFFFFF;
endmodule


