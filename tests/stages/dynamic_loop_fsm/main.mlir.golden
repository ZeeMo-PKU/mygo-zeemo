module {
  hw.module @main() {
    %c_init_input = hw.constant 0 : i256
    %input = sv.reg : !hw.inout<i256>
    sv.initial {
      sv.bpassign %input, %c_init_input : i256
    }
    %c_init_input_0 = hw.constant 0 : i32
    %input_0 = sv.reg : !hw.inout<i32>
    sv.initial {
      sv.bpassign %input_0, %c_init_input_0 : i32
    }
    %c_init_input_1 = hw.constant 0 : i32
    %input_1 = sv.reg : !hw.inout<i32>
    sv.initial {
      sv.bpassign %input_1, %c_init_input_1 : i32
    }
    %c_init_input_2 = hw.constant 0 : i32
    %input_2 = sv.reg : !hw.inout<i32>
    sv.initial {
      sv.bpassign %input_2, %c_init_input_2 : i32
    }
    %c_init_input_3 = hw.constant 0 : i32
    %input_3 = sv.reg : !hw.inout<i32>
    sv.initial {
      sv.bpassign %input_3, %c_init_input_3 : i32
    }
    %c_init_input_4 = hw.constant 0 : i32
    %input_4 = sv.reg : !hw.inout<i32>
    sv.initial {
      sv.bpassign %input_4, %c_init_input_4 : i32
    }
    %c_init_input_5 = hw.constant 0 : i32
    %input_5 = sv.reg : !hw.inout<i32>
    sv.initial {
      sv.bpassign %input_5, %c_init_input_5 : i32
    }
    %c_init_input_6 = hw.constant 0 : i32
    %input_6 = sv.reg : !hw.inout<i32>
    sv.initial {
      sv.bpassign %input_6, %c_init_input_6 : i32
    }
    %c_init_input_7 = hw.constant 0 : i32
    %input_7 = sv.reg : !hw.inout<i32>
    sv.initial {
      sv.bpassign %input_7, %c_init_input_7 : i32
    }
    %c0 = hw.constant 0 : i32
    %c1 = hw.constant 32 : i256
    %c2 = hw.constant 4294967295 : i256
    %c3 = hw.constant 8 : i32
    %c4 = hw.constant 1 : i32
    %v5 = arith.extsi %c0 : i32 to i256
    %v6 = comb.mul %v5, %c1 : i256
    %v7 = sv.read_inout %input_0 : !hw.inout<i32>
    %v8 = sv.read_inout %input_1 : !hw.inout<i32>
    %v9 = sv.read_inout %input_2 : !hw.inout<i32>
    %v10 = sv.read_inout %input_3 : !hw.inout<i32>
    %v11 = sv.read_inout %input_4 : !hw.inout<i32>
    %v12 = sv.read_inout %input_5 : !hw.inout<i32>
    %v13 = sv.read_inout %input_6 : !hw.inout<i32>
    %v14 = sv.read_inout %input_7 : !hw.inout<i32>
    %packed15 = comb.concat %v14, %v13, %v12, %v11, %v10, %v9, %v8, %v7 : i32, i32, i32, i32, i32, i32, i32, i32
    %v16 = comb.shru %packed15, %v6 : i256
    %v17 = comb.and %v16, %c2 : i256
    %v18 = arith.trunci %v17 : i256 to i32
    %c_zero20 = hw.constant 0 : i32
    %c_bool_0 = hw.constant 1 : i1
    %v22 = comb.icmp slt %c0, %c3 : i32
    %v23 = arith.extsi %c0 : i32 to i256
    %v24 = comb.mul %v23, %c1 : i256
    %v25 = comb.shru %packed15, %v24 : i256
    %v26 = comb.and %v25, %c2 : i256
    %v27 = arith.trunci %v26 : i256 to i32
    %v28 = comb.icmp sgt %v27, %v18 : i32
    %v29 = arith.extsi %c0 : i32 to i256
    %v30 = comb.mul %v29, %c1 : i256
    %v31 = comb.shru %packed15, %v30 : i256
    %v32 = comb.and %v31, %c2 : i256
    %v33 = arith.trunci %v32 : i256 to i32
    %phi_not35 = comb.xor %v28, %c_bool_0 : i1
    %phi_and36 = comb.and %phi_not35, %v22 : i1
    %c_bool_1 = hw.constant 0 : i1
    %v34 = comb.mux %phi_and36, %v18, %v33 : i32
    %v37 = comb.add %c0, %c4 : i32
    hw.output
  }
}
