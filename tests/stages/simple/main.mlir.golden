module {
  hw.module @main(in %clk: i1, in %rst: i1) {
    %c_init_varargs = hw.constant 0 : i32
    %varargs = sv.reg : !hw.inout<i32>
    sv.initial {
      sv.bpassign %varargs, %c_init_varargs : i32
    }
    %c0 = hw.constant 1 : i32
    %c1 = hw.constant 2 : i16
    %state_const2 = hw.constant 0 : i1
    %state_const3 = hw.constant 1 : i1
    %state_reg4 = sv.reg : !hw.inout<i1>
    sv.initial {
      sv.bpassign %state_reg4, %state_const2 : i1
    }
    %state5 = sv.read_inout %state_reg4 : !hw.inout<i1>
    %print_reg6 = sv.reg : !hw.inout<i64>
    %print_zero7 = hw.constant 0 : i64
    sv.initial {
      sv.bpassign %print_reg6, %print_zero7 : i64
    }
    %sext_msb9 = comb.extract %c0 from 31 : (i32) -> i1
    %sext_bits10 = comb.replicate %sext_msb9 : (i1) -> i32
    %v8 = comb.concat %sext_bits10, %c0 : i32, i32
    %sext_msb12 = comb.extract %c1 from 15 : (i16) -> i1
    %sext_bits13 = comb.replicate %sext_msb12 : (i1) -> i48
    %v11 = comb.concat %sext_bits13, %c1 : i48, i16
    %v14 = comb.add %v8, %v11 : i64
    %stdout_fd15 = hw.constant 2147483649 : i32
    sv.always posedge %clk {
      sv.if %rst {
        sv.passign %state_reg4, %state_const2 : i1
      } else {
        sv.case %state5 : i1
        case b0: {
          sv.bpassign %print_reg6, %v14 : i64
          %print_val16 = sv.read_inout %print_reg6 : !hw.inout<i64>
          sv.fwrite %stdout_fd15, "The result is small: %0d\n"(%print_val16) : i64
          sv.passign %state_reg4, %state_const3 : i1
        }
        case b1: {
          sv.passign %state_reg4, %state5 : i1
        }
        default: {
          sv.passign %state_reg4, %state5 : i1
        }
      }
    }
    hw.output
  }
}
