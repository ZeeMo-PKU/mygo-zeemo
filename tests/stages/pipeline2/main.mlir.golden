    %state_reg28 = sv.reg : !hw.inout<i4>
    sv.initial {
      sv.bpassign %state_reg28, %state_const19 : i4
    }
    %state29 = sv.read_inout %state_reg28 : !hw.inout<i4>
    %print_reg30 = sv.reg : !hw.inout<i32>
    %print_zero31 = hw.constant 0 : i32
    sv.initial {
      sv.bpassign %print_reg30, %print_zero31 : i32
    }
    %phi_reg32 = sv.reg : !hw.inout<i32>
    %v33 = sv.read_inout %phi_reg32 : !hw.inout<i32>
    %v34 = comb.icmp ult %v33, %c17 : i32
    %v35 = comb.add %v33, %v33 : i32
    %v36 = comb.add %v33, %c18 : i32
    %stdout_fd37 = hw.constant 2147483649 : i32
    %state_is38 = comb.icmp eq %state29, %state_const20 : i4
    %state_is39 = comb.icmp eq %state29, %state_const25 : i4
    %or40 = comb.or %state_is38, %state_is39 : i1
    sv.assign %chan_t0_wvalid, %or40 : i1
    %c_zero41 = hw.constant 0 : i32
    %mux42 = comb.mux %state_is39, %v35, %c_zero41 : i32
    %mux43 = comb.mux %state_is38, %c15, %mux42 : i32
    sv.assign %chan_t0_wdata, %mux43 : i32
    %send_ready44 = sv.read_inout %chan_t0_wready : !hw.inout<i1>
    sv.always posedge %clk {
      sv.if %rst {
        sv.passign %state_reg28, %state_const19 : i4
      } else {
        sv.case %state29 : i4
        case b0000: {
          sv.passign %state_reg28, %state_const20 : i4
        }
        case b0001: {
          sv.if %send_ready44 {
            sv.passign %state_reg28, %state_const21 : i4
          } else {
            sv.passign %state_reg28, %state29 : i4
          }
        }
        case b0010: {
          sv.passign %state_reg28, %state_const22 : i4
          sv.passign %phi_reg32, %c16 : i32
        }
        case b0011: {
          sv.if %v34 {
            sv.passign %state_reg28, %state_const24 : i4
          } else {
            sv.passign %state_reg28, %state_const23 : i4
          }
        }
        case b0100: {
          sv.passign %state_reg28, %state_const27 : i4
        }
        case b0101: {
          sv.passign %state_reg28, %state_const25 : i4
        }
        case b0110: {
          sv.if %send_ready44 {
            sv.passign %state_reg28, %state_const26 : i4
          } else {
            sv.passign %state_reg28, %state29 : i4
          }
        }
        case b0111: {
          sv.bpassign %print_reg30, %v35 : i32
          %print_val45 = sv.read_inout %print_reg30 : !hw.inout<i32>
          sv.fwrite %stdout_fd37, "stage 1: sent integer %0d\n"(%print_val45) : i32
