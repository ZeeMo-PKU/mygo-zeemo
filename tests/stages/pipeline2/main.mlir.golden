    %chan_t2_rst_n = comb.xor %rst, %chan_t2_one : i1
    hw.instance "t2_fifo" @mygo_fifo_i1_d2(clk: %clk : i1, rst_n: %chan_t2_rst_n : i1, wr_en: %chan_t2_wvalid : !hw.inout<i1>, wr_data: %chan_t2_wdata : !hw.inout<i1>, full: %chan_t2_full : !hw.inout<i1>, almost_full: %chan_t2_almost_full : !hw.inout<i1>, rd_en: %chan_t2_rready : !hw.inout<i1>, rd_data: %chan_t2_rdata : !hw.inout<i1>, empty: %chan_t2_empty : !hw.inout<i1>, almost_empty: %chan_t2_almost_empty : !hw.inout<i1>) -> ()
