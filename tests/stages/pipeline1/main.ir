module main
  ports:
    in  clk 1bu
    in  rst 1bu
  signals:
    const_0  const 1bu = true
    const_10 const 32bu = 1
    const_11 const 1bu = true
    const_13 const 32bu = 5
    const_15 const 32bu = 0
    const_17 const 32bu = 5
    const_20 const 32bu = 426771240
    const_23 const 32bu = 537200675
    const_24 const 32bu = 537334308
    const_25 const 32bu = 1
    const_26 const 32bu = 426770689
    const_28 const 32bu = 5
    const_3  const 32bu = 0
    const_30 const 32bu = 0
    const_32 const 32bu = 5
    const_34 const 32bu = 1
    const_37 const 32bu = 426771240
    const_38 const 32bu = 426770689
    const_39 const 32bs = 0
    const_40 const 32bs = 0
    const_41 const 32bu = 1
    const_42 const 32bu = 2
    const_45 const 32bs = 0
    const_5  const 32bu = 5
    const_8  const 32bs = 0
    const_9  const 32bs = 0
    t0_1     wire  32bu
    t0_12    wire  32bu
    t0_29    wire  32bu
    t11_31   wire  32bu
    t11_4    wire  32bu
    t12_43   wire  1bu
    t1_14    wire  32bu
    t1_2     wire  32bu
    t1_33    wire  1bu
    t2_18    wire  1bu
    t2_35    wire  1bu
    t2_6     wire  1bu
    t3_19    wire  32bu
    t3_36    wire  32bu
    t3_7     wire  32bu
    t4_21    wire  1bu
    t5_22    wire  32bu
    t6_16    wire  32bu
    t7_27    wire  1bu
    t8_44    wire  1bu
    varargs  reg   32bs
  channels:
    t0       depth=2 type=32bu
    t1       depth=4 type=32bu
    t2       depth=2 type=1bu
  process 0 main (stage=0, sequential)
    block entry
      go sink(stage=1)(ch:t1, t2)
      go filter(stage=2)(ch:t0, t1)
      go source(stage=3)(ch:t0)
      t8_44 <- t2
      print "finished is "%0s(t8_44)"\n"
      return
  process 1 sink (stage=1, sequential)
    block entry
      t0_1 <- t1
      jump for.loop
    block for.loop
      t1_2 := phi[entry:const_3, for.body:t11_4]
      t2_6 := cmp(t1_2 <u const_5)
      br t2_6 ? for.body : for.done
    block for.done
      send t2 <- const_11
      return
    block for.body
      t3_7 <- t1
      print "output: count "%0d(t1_2)" got integer 0x"%0x(t3_7)"\n"
      t11_4 := t1_2 + const_10
      jump for.loop
  process 2 filter (stage=2, sequential)
    block entry
      t0_12 <- t0
      send t1 <- const_13
      jump for.loop
    block for.loop
      t1_14 := phi[entry:const_15, if.done:t6_16]
      t2_18 := cmp(t1_14 <u const_17)
      br t2_18 ? for.body : for.done
    block for.done
      return
    block for.body
      t3_19 <- t0
      t4_21 := cmp(t3_19 == const_20)
      br t4_21 ? if.then : if.else
    block if.else
      t7_27 := cmp(t3_19 == const_26)
      br t7_27 ? if.then : if.done
    block if.then
      jump if.done
    block if.then
      jump if.done
    block if.done
      t5_22 := phi[if.then:const_23, if.else:t3_19, if.then:const_24]
      send t1 <- t5_22
      t6_16 := t1_14 + const_25
      jump for.loop
  process 3 source (stage=3, sequential)
    block entry
      send t0 <- const_28
      jump for.loop
    block for.loop
      t0_29 := phi[entry:const_30, if.done:t11_31]
      t1_33 := cmp(t0_29 <u const_32)
      br t1_33 ? for.body : for.done
    block for.done
      return
    block for.body
      t2_35 := cmp(t0_29 == const_34)
      br t2_35 ? if.then : if.else
    block if.else
      t12_43 := cmp(t0_29 == const_42)
      br t12_43 ? if.then : if.done
    block if.then
      jump if.done
    block if.then
      jump if.done
    block if.done
      t3_36 := phi[if.then:const_37, if.else:t0_29, if.then:const_38]
      send t0 <- t3_36
      print "input: count "%0d(t0_29)" sent integer 0x"%0x(t3_36)"\n"
      t11_31 := t0_29 + const_41
      jump for.loop

