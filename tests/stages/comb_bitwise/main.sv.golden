module main(
  input clk,
        rst
);

  reg signed [31:0] varargs;
  initial
    varargs = 32'h0;
  reg        state_reg4;
  initial
    state_reg4 = 1'h0;
  reg [15:0] print_reg6;
  initial
    print_reg6 = 16'h0;
  reg [15:0] print_reg8;
  initial
    print_reg8 = 16'h0;
  reg [15:0] print_reg10;
  initial
    print_reg10 = 16'h0;
  always @(posedge clk) begin
    if (rst)
      state_reg4 <= 1'h0;
    else begin
      case (state_reg4)
        1'b0: begin
          print_reg6 = 16'h33CC & 16'hF0F;
          print_reg8 = 16'h33CC | 16'hF0F;
          print_reg10 = 16'h33CC ^ 16'hF0F;
          $write("and=0x%0x or=0x%0x xor=0x%0x\n", print_reg6, print_reg8,
                  print_reg10);
          state_reg4 <= 1'h1;
        end
        1'b1:
          state_reg4 <= state_reg4;
        default:
          state_reg4 <= state_reg4;
      endcase
    end
  end // always @(posedge)
endmodule

