module main
  ports:
    in  clk 1bu
    in  rst 1bu
  signals:
    const_0  const 1bu = true
    const_1  const 16bu = 13260
    const_2  const 16bu = 3855
    const_6  const 32bs = 0
    const_7  const 32bs = 0
    const_8  const 32bs = 0
    t0_3     wire  16bu
    t1_4     wire  16bu
    t2_5     wire  16bu
    varargs  reg   32bs
  process 0 main (stage=0, sequential)
    block entry
      t0_3 := const_1 & const_2
      t1_4 := const_1 | const_2
      t2_5 := const_1 ^ const_2
      print "and=0x"%0x(t0_3)" or=0x"%0x(t1_4)" xor=0x"%0x(t2_5)"\n"
      return

