module main
  ports:
    in  clk 1bu
    in  rst 1bu
  signals:
    const_0  const 1bu = true
    const_12 const 32bs = 0
    const_14 const 32bs = 4
    const_17 const 32bs = 0
    const_18 const 32bs = 0
    const_19 const 32bs = 1
    const_2  const 32bs = 0
    const_21 const 32bs = 42
    const_23 const 32bs = 0
    const_4  const 32bs = 4
    const_6  const 32bs = 0
    const_7  const 32bs = 1
    const_9  const 32bs = 0
    t0_1     wire  32bs
    t0_8     wire  32bs
    t12_13   wire  32bs
    t1_11    wire  32bs
    t1_5     wire  1bu
    t2_15    wire  1bu
    t3_16    wire  32bs
    t4_10    wire  32bs
    t5_20    wire  32bs
    t6_22    wire  1bu
    t7_3     wire  32bs
    varargs  reg   32bs
  channels:
    t0       depth=2 type=32bs
    t1       depth=2 type=32bs
  process 0 main (stage=0, sequential)
    block entry
      go producer(stage=1)(ch:t0)
      go consumer(stage=2)(ch:t0, t1)
      t5_20 <- t1
      t6_22 := cmp(t5_20 == const_21)
      br t6_22 ? if.then : if.done
    block if.then
      send t0 <- t5_20
      jump if.done
    block if.done
      print "phi loop final="%0d(t5_20)"\n"
      return
  process 1 producer (stage=1, sequential)
    block entry
      jump for.loop
    block for.loop
      t0_1 := phi[entry:const_2, for.body:t7_3]
      t1_5 := cmp(t0_1 <s const_4)
      br t1_5 ? for.body : for.done
    block for.done
      return
    block for.body
      send t0 <- t0_1
      print "producer sent "%0d(t0_1)"\n"
      t7_3 := t0_1 + const_7
      jump for.loop
  process 2 consumer (stage=2, sequential)
    block entry
      jump for.loop
    block for.loop
      t0_8 := phi[entry:const_9, for.body:t4_10]
      t1_11 := phi[entry:const_12, for.body:t12_13]
      t2_15 := cmp(t1_11 <s const_14)
      br t2_15 ? for.body : for.done
    block for.done
      send t1 <- t0_8
      return
    block for.body
      t3_16 <- t0
      t4_10 := t0_8 + t3_16
      print "consumer received "%0d(t3_16)" (running total "%0d(t4_10)")\n"
      t12_13 := t1_11 + const_19
      jump for.loop

