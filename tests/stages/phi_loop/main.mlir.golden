module {
  hw.module @main(in %clk: i1, in %rst: i1) {
    // channel t0 depth=2 type=i32
    %chan_t0_wdata = sv.wire : !hw.inout<i32>
    %chan_t0_wvalid = sv.wire : !hw.inout<i1>
    %chan_t0_wready = sv.wire : !hw.inout<i1>
    %chan_t0_rdata = sv.wire : !hw.inout<i32>
    %chan_t0_rvalid = sv.wire : !hw.inout<i1>
    %chan_t0_rready = sv.wire : !hw.inout<i1>
    %chan_t0_full = sv.wire : !hw.inout<i1>
    %chan_t0_almost_full = sv.wire : !hw.inout<i1>
    %chan_t0_empty = sv.wire : !hw.inout<i1>
    %chan_t0_almost_empty = sv.wire : !hw.inout<i1>
    %chan_t0_prod0_main_wdata = sv.wire : !hw.inout<i32>
    %chan_t0_prod0_main_wvalid = sv.wire : !hw.inout<i1>
    %chan_t0_prod0_main_wready = sv.wire : !hw.inout<i1>
    %chan_t0_prod1_producer_wdata = sv.wire : !hw.inout<i32>
    %chan_t0_prod1_producer_wvalid = sv.wire : !hw.inout<i1>
    %chan_t0_prod1_producer_wready = sv.wire : !hw.inout<i1>
    // channel t0 occupancy 1/2
    //   producer producer stage 1
    //   producer main stage 0
    //   consumer consumer stage 2
    // channel t1 depth=2 type=i32
    %chan_t1_wdata = sv.wire : !hw.inout<i32>
    %chan_t1_wvalid = sv.wire : !hw.inout<i1>
    %chan_t1_wready = sv.wire : !hw.inout<i1>
    %chan_t1_rdata = sv.wire : !hw.inout<i32>
    %chan_t1_rvalid = sv.wire : !hw.inout<i1>
    %chan_t1_rready = sv.wire : !hw.inout<i1>
    %chan_t1_full = sv.wire : !hw.inout<i1>
    %chan_t1_almost_full = sv.wire : !hw.inout<i1>
    %chan_t1_empty = sv.wire : !hw.inout<i1>
    %chan_t1_almost_empty = sv.wire : !hw.inout<i1>
    // channel t1 occupancy 0/2
    //   producer consumer stage 2
    //   consumer main stage 0
    %chan_t0_one = hw.constant 1 : i1
    %chan_t0_rst_n = comb.xor %rst, %chan_t0_one : i1
    hw.instance "t0_fifo" @mygo_fifo_i32_d2(clk: %clk : i1, rst_n: %chan_t0_rst_n : i1, wr_en: %chan_t0_wvalid : !hw.inout<i1>, wr_data: %chan_t0_wdata : !hw.inout<i32>, full: %chan_t0_full : !hw.inout<i1>, almost_full: %chan_t0_almost_full : !hw.inout<i1>, rd_en: %chan_t0_rready : !hw.inout<i1>, rd_data: %chan_t0_rdata : !hw.inout<i32>, empty: %chan_t0_empty : !hw.inout<i1>, almost_empty: %chan_t0_almost_empty : !hw.inout<i1>) -> ()
    %chan_t0_full_val = sv.read_inout %chan_t0_full : !hw.inout<i1>
    %chan_t0_not_full = comb.xor %chan_t0_full_val, %chan_t0_one : i1
    %mp_valid0 = sv.read_inout %chan_t0_prod0_main_wvalid : !hw.inout<i1>
    %mp_data1 = sv.read_inout %chan_t0_prod0_main_wdata : !hw.inout<i32>
    %mp_valid2 = sv.read_inout %chan_t0_prod1_producer_wvalid : !hw.inout<i1>
    %mp_data3 = sv.read_inout %chan_t0_prod1_producer_wdata : !hw.inout<i32>
    %mp_no_prior4 = comb.xor %mp_valid0, %chan_t0_one : i1
    %mp_grant5 = comb.and %mp_valid2, %mp_no_prior4 : i1
    %mp_prior6 = comb.or %mp_valid0, %mp_valid2 : i1
    %or7 = comb.or %mp_valid0, %mp_valid2 : i1
    sv.assign %chan_t0_wvalid, %or7 : i1
    %c_zero8 = hw.constant 0 : i32
    %mux9 = comb.mux %mp_grant5, %mp_data3, %c_zero8 : i32
    %mux10 = comb.mux %mp_valid0, %mp_data1, %mux9 : i32
    sv.assign %chan_t0_wdata, %mux10 : i32
    %mp_ready11 = comb.and %mp_valid0, %chan_t0_not_full : i1
    sv.assign %chan_t0_prod0_main_wready, %mp_ready11 : i1
    %mp_ready12 = comb.and %mp_grant5, %chan_t0_not_full : i1
    sv.assign %chan_t0_prod1_producer_wready, %mp_ready12 : i1
    %chan_t0_empty_val = sv.read_inout %chan_t0_empty : !hw.inout<i1>
    %chan_t0_not_empty = comb.xor %chan_t0_empty_val, %chan_t0_one : i1
    sv.assign %chan_t0_rvalid, %chan_t0_not_empty : i1
    %chan_t1_one = hw.constant 1 : i1
    %chan_t1_rst_n = comb.xor %rst, %chan_t1_one : i1
    hw.instance "t1_fifo" @mygo_fifo_i32_d2(clk: %clk : i1, rst_n: %chan_t1_rst_n : i1, wr_en: %chan_t1_wvalid : !hw.inout<i1>, wr_data: %chan_t1_wdata : !hw.inout<i32>, full: %chan_t1_full : !hw.inout<i1>, almost_full: %chan_t1_almost_full : !hw.inout<i1>, rd_en: %chan_t1_rready : !hw.inout<i1>, rd_data: %chan_t1_rdata : !hw.inout<i32>, empty: %chan_t1_empty : !hw.inout<i1>, almost_empty: %chan_t1_almost_empty : !hw.inout<i1>) -> ()
    %chan_t1_full_val = sv.read_inout %chan_t1_full : !hw.inout<i1>
    %chan_t1_not_full = comb.xor %chan_t1_full_val, %chan_t1_one : i1
    sv.assign %chan_t1_wready, %chan_t1_not_full : i1
    %chan_t1_empty_val = sv.read_inout %chan_t1_empty : !hw.inout<i1>
    %chan_t1_not_empty = comb.xor %chan_t1_empty_val, %chan_t1_one : i1
    sv.assign %chan_t1_rvalid, %chan_t1_not_empty : i1
    %c_init_varargs = hw.constant 0 : i32
    %varargs = sv.reg : !hw.inout<i32>
    sv.initial {
      sv.bpassign %varargs, %c_init_varargs : i32
    }
    %c13 = hw.constant 42 : i32
    %state_const14 = hw.constant 0 : i3
    %state_const15 = hw.constant 1 : i3
    %state_const16 = hw.constant 2 : i3
    %state_const17 = hw.constant 3 : i3
    %state_const18 = hw.constant 4 : i3
    %state_const19 = hw.constant 5 : i3
    %state_const20 = hw.constant 6 : i3
    %state_const21 = hw.constant 7 : i3
    %state_reg22 = sv.reg : !hw.inout<i3>
    sv.initial {
      sv.bpassign %state_reg22, %state_const14 : i3
    }
    %state23 = sv.read_inout %state_reg22 : !hw.inout<i3>
    %recv_reg24 = sv.reg : !hw.inout<i32>
    %v25 = sv.read_inout %recv_reg24 : !hw.inout<i32>
    %print_reg26 = sv.reg : !hw.inout<i32>
    %print_zero27 = hw.constant 0 : i32
    sv.initial {
      sv.bpassign %print_reg26, %print_zero27 : i32
    }
    // spawn producer stage=1 parent_stage=0
    // spawn consumer stage=2 parent_stage=0
    %v28 = comb.icmp eq %v25, %c13 : i32
    %stdout_fd29 = hw.constant 2147483649 : i32
    %state_is30 = comb.icmp eq %state23, %state_const18 : i3
    %state_is31 = comb.icmp eq %state23, %state_const15 : i3
    sv.assign %chan_t0_prod0_main_wvalid, %state_is30 : i1
    %c_zero32 = hw.constant 0 : i32
    %mux33 = comb.mux %state_is30, %v25, %c_zero32 : i32
    sv.assign %chan_t0_prod0_main_wdata, %mux33 : i32
    %send_ready34 = sv.read_inout %chan_t0_prod0_main_wready : !hw.inout<i1>
    sv.assign %chan_t1_rready, %state_is31 : i1
    %recv_valid35 = sv.read_inout %chan_t1_rvalid : !hw.inout<i1>
    %recv_data36 = sv.read_inout %chan_t1_rdata : !hw.inout<i32>
    sv.always posedge %clk {
      sv.if %rst {
        sv.passign %state_reg22, %state_const14 : i3
      } else {
        sv.case %state23 : i3
        case b000: {
          sv.passign %state_reg22, %state_const15 : i3
        }
        case b001: {
          sv.if %recv_valid35 {
            sv.passign %recv_reg24, %recv_data36 : i32
            sv.passign %state_reg22, %state_const16 : i3
          } else {
            sv.passign %state_reg22, %state23 : i3
          }
        }
        case b010: {
          sv.if %v28 {
            sv.passign %state_reg22, %state_const17 : i3
          } else {
            sv.passign %state_reg22, %state_const20 : i3
          }
        }
        case b011: {
          sv.passign %state_reg22, %state_const18 : i3
        }
        case b100: {
          sv.if %send_ready34 {
            sv.passign %state_reg22, %state_const19 : i3
          } else {
            sv.passign %state_reg22, %state23 : i3
          }
        }
        case b101: {
          sv.passign %state_reg22, %state_const20 : i3
        }
        case b110: {
          sv.bpassign %print_reg26, %v25 : i32
          %print_val37 = sv.read_inout %print_reg26 : !hw.inout<i32>
          sv.fwrite %stdout_fd29, "phi loop final=%0d\n"(%print_val37) : i32
          sv.passign %state_reg22, %state_const21 : i3
        }
        case b111: {
          sv.passign %state_reg22, %state23 : i3
        }
        default: {
          sv.passign %state_reg22, %state23 : i3
        }
      }
    }
    hw.instance "consumer_inst0" @main__proc_consumer(clk: %clk : i1, rst: %rst : i1, chan_t0_rdata: %chan_t0_rdata : !hw.inout<i32>, chan_t0_rvalid: %chan_t0_rvalid : !hw.inout<i1>, chan_t0_rready: %chan_t0_rready : !hw.inout<i1>, chan_t1_wdata: %chan_t1_wdata : !hw.inout<i32>, chan_t1_wvalid: %chan_t1_wvalid : !hw.inout<i1>, chan_t1_wready: %chan_t1_wready : !hw.inout<i1>) -> ()
    hw.instance "producer_inst1" @main__proc_producer(clk: %clk : i1, rst: %rst : i1, chan_t0_wdata: %chan_t0_prod1_producer_wdata : !hw.inout<i32>, chan_t0_wvalid: %chan_t0_prod1_producer_wvalid : !hw.inout<i1>, chan_t0_wready: %chan_t0_prod1_producer_wready : !hw.inout<i1>) -> ()
    hw.output
  }
  hw.module @main__proc_consumer(in %clk: i1, in %rst: i1, inout %chan_t0_rdata: i32, inout %chan_t0_rvalid: i1, inout %chan_t0_rready: i1, inout %chan_t1_wdata: i32, inout %chan_t1_wvalid: i1, inout %chan_t1_wready: i1) {
    %c38 = hw.constant 0 : i32
    %c39 = hw.constant 4 : i32
    %c40 = hw.constant 1 : i32
    %c41 = hw.constant 0 : i32
    %state_const42 = hw.constant 0 : i4
    %state_const43 = hw.constant 1 : i4
    %state_const44 = hw.constant 2 : i4
    %state_const45 = hw.constant 3 : i4
    %state_const46 = hw.constant 4 : i4
    %state_const47 = hw.constant 5 : i4
    %state_const48 = hw.constant 6 : i4
    %state_const49 = hw.constant 7 : i4
    %state_const50 = hw.constant 8 : i4
    %state_reg51 = sv.reg : !hw.inout<i4>
    sv.initial {
      sv.bpassign %state_reg51, %state_const42 : i4
    }
    %state52 = sv.read_inout %state_reg51 : !hw.inout<i4>
    %recv_reg53 = sv.reg : !hw.inout<i32>
    %v54 = sv.read_inout %recv_reg53 : !hw.inout<i32>
    %print_reg55 = sv.reg : !hw.inout<i32>
    %print_zero56 = hw.constant 0 : i32
    sv.initial {
      sv.bpassign %print_reg55, %print_zero56 : i32
    }
    %print_reg57 = sv.reg : !hw.inout<i32>
    %print_zero58 = hw.constant 0 : i32
    sv.initial {
      sv.bpassign %print_reg57, %print_zero58 : i32
    }
    %phi_reg59 = sv.reg : !hw.inout<i32>
    %v60 = sv.read_inout %phi_reg59 : !hw.inout<i32>
    %phi_reg61 = sv.reg : !hw.inout<i32>
    %v62 = sv.read_inout %phi_reg61 : !hw.inout<i32>
    %v63 = comb.icmp slt %v62, %c39 : i32
    %v64 = comb.add %v60, %v54 : i32
    %v65 = comb.add %v62, %c40 : i32
    %stdout_fd66 = hw.constant 2147483649 : i32
    %state_is67 = comb.icmp eq %state52, %state_const45 : i4
    %state_is68 = comb.icmp eq %state52, %state_const48 : i4
    sv.assign %chan_t1_wvalid, %state_is67 : i1
    %c_zero69 = hw.constant 0 : i32
    %mux70 = comb.mux %state_is67, %v60, %c_zero69 : i32
    sv.assign %chan_t1_wdata, %mux70 : i32
    %send_ready71 = sv.read_inout %chan_t1_wready : !hw.inout<i1>
    sv.assign %chan_t0_rready, %state_is68 : i1
    %recv_valid72 = sv.read_inout %chan_t0_rvalid : !hw.inout<i1>
    %recv_data73 = sv.read_inout %chan_t0_rdata : !hw.inout<i32>
    sv.always posedge %clk {
      sv.if %rst {
        sv.passign %state_reg51, %state_const42 : i4
      } else {
        sv.case %state52 : i4
        case b0000: {
          sv.passign %state_reg51, %state_const43 : i4
          sv.passign %phi_reg59, %c41 : i32
          sv.passign %phi_reg61, %c38 : i32
        }
        case b0001: {
          sv.if %v63 {
            sv.passign %state_reg51, %state_const47 : i4
          } else {
            sv.passign %state_reg51, %state_const44 : i4
          }
        }
        case b0010: {
          sv.passign %state_reg51, %state_const45 : i4
        }
        case b0011: {
          sv.if %send_ready71 {
            sv.passign %state_reg51, %state_const46 : i4
          } else {
            sv.passign %state_reg51, %state52 : i4
          }
        }
        case b0100: {
          sv.passign %state_reg51, %state_const50 : i4
        }
        case b0101: {
          sv.passign %state_reg51, %state_const48 : i4
        }
        case b0110: {
          sv.if %recv_valid72 {
            sv.passign %recv_reg53, %recv_data73 : i32
            sv.passign %state_reg51, %state_const49 : i4
          } else {
            sv.passign %state_reg51, %state52 : i4
          }
        }
        case b0111: {
          sv.bpassign %print_reg55, %v54 : i32
          %print_val74 = sv.read_inout %print_reg55 : !hw.inout<i32>
          sv.bpassign %print_reg57, %v64 : i32
          %print_val75 = sv.read_inout %print_reg57 : !hw.inout<i32>
          sv.fwrite %stdout_fd66, "consumer received %0d (running total %0d)\n"(%print_val74, %print_val75) : i32, i32
          sv.passign %state_reg51, %state_const43 : i4
          sv.passign %phi_reg59, %v64 : i32
          sv.passign %phi_reg61, %v65 : i32
        }
        case b1000: {
          sv.passign %state_reg51, %state52 : i4
        }
        default: {
          sv.passign %state_reg51, %state52 : i4
        }
      }
    }
  }
  hw.module @main__proc_producer(in %clk: i1, in %rst: i1, inout %chan_t0_wdata: i32, inout %chan_t0_wvalid: i1, inout %chan_t0_wready: i1) {
    %c76 = hw.constant 0 : i32
    %c77 = hw.constant 4 : i32
    %c78 = hw.constant 1 : i32
    %state_const79 = hw.constant 0 : i3
    %state_const80 = hw.constant 1 : i3
    %state_const81 = hw.constant 2 : i3
    %state_const82 = hw.constant 3 : i3
    %state_const83 = hw.constant 4 : i3
    %state_const84 = hw.constant 5 : i3
    %state_const85 = hw.constant 6 : i3
    %state_reg86 = sv.reg : !hw.inout<i3>
    sv.initial {
      sv.bpassign %state_reg86, %state_const79 : i3
    }
    %state87 = sv.read_inout %state_reg86 : !hw.inout<i3>
    %print_reg88 = sv.reg : !hw.inout<i32>
    %print_zero89 = hw.constant 0 : i32
    sv.initial {
      sv.bpassign %print_reg88, %print_zero89 : i32
    }
    %phi_reg90 = sv.reg : !hw.inout<i32>
    %v91 = sv.read_inout %phi_reg90 : !hw.inout<i32>
    %v92 = comb.icmp slt %v91, %c77 : i32
    %v93 = comb.add %v91, %c78 : i32
    %stdout_fd94 = hw.constant 2147483649 : i32
    %state_is95 = comb.icmp eq %state87, %state_const83 : i3
    sv.assign %chan_t0_wvalid, %state_is95 : i1
    %c_zero96 = hw.constant 0 : i32
    %mux97 = comb.mux %state_is95, %v91, %c_zero96 : i32
    sv.assign %chan_t0_wdata, %mux97 : i32
    %send_ready98 = sv.read_inout %chan_t0_wready : !hw.inout<i1>
    sv.always posedge %clk {
      sv.if %rst {
        sv.passign %state_reg86, %state_const79 : i3
      } else {
        sv.case %state87 : i3
        case b000: {
          sv.passign %state_reg86, %state_const80 : i3
          sv.passign %phi_reg90, %c76 : i32
        }
        case b001: {
          sv.if %v92 {
            sv.passign %state_reg86, %state_const82 : i3
          } else {
            sv.passign %state_reg86, %state_const81 : i3
          }
        }
        case b010: {
          sv.passign %state_reg86, %state_const85 : i3
        }
        case b011: {
          sv.passign %state_reg86, %state_const83 : i3
        }
        case b100: {
          sv.if %send_ready98 {
            sv.passign %state_reg86, %state_const84 : i3
          } else {
            sv.passign %state_reg86, %state87 : i3
          }
        }
        case b101: {
          sv.bpassign %print_reg88, %v91 : i32
          %print_val99 = sv.read_inout %print_reg88 : !hw.inout<i32>
          sv.fwrite %stdout_fd94, "producer sent %0d\n"(%print_val99) : i32
          sv.passign %state_reg86, %state_const80 : i3
          sv.passign %phi_reg90, %v93 : i32
        }
        case b110: {
          sv.passign %state_reg86, %state87 : i3
        }
        default: {
          sv.passign %state_reg86, %state87 : i3
        }
      }
    }
  }
  hw.module @mygo_fifo_i32_d2(in %clk: i1, in %rst_n: i1, inout %wr_en: i1, inout %wr_data: i32, inout %full: i1, inout %almost_full: i1, inout %rd_en: i1, inout %rd_data: i32, inout %empty: i1, inout %almost_empty: i1) {
    hw.output
  }
}
