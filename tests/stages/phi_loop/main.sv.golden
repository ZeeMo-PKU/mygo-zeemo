module main(
  input clk,
        rst
);

  wire signed [31:0] chan_t0_wdata;
  wire        chan_t0_wvalid;
  wire        chan_t0_wready;
  wire signed [31:0] chan_t0_rdata;
  wire        chan_t0_rvalid;
  wire        chan_t0_rready;
  wire        chan_t0_full;
  wire        chan_t0_almost_full;
  wire        chan_t0_empty;
  wire        chan_t0_almost_empty;
  wire [31:0] chan_t0_prod0_main_wdata;
  wire        chan_t0_prod0_main_wvalid;
  wire        chan_t0_prod0_main_wready;
  wire [31:0] chan_t0_prod1_producer_wdata;
  wire        chan_t0_prod1_producer_wvalid;
  wire        chan_t0_prod1_producer_wready;
  wire signed [31:0] chan_t1_wdata;
  wire        chan_t1_wvalid;
  wire        chan_t1_wready;
  wire signed [31:0] chan_t1_rdata;
  wire        chan_t1_rvalid;
  wire        chan_t1_rready;
  wire        chan_t1_full;
  wire        chan_t1_almost_full;
  wire        chan_t1_empty;
  wire        chan_t1_almost_empty;
  mygo_fifo #(.DATA_WIDTH(32), .DEPTH(2), .ADDR_WIDTH(1), .COUNT_WIDTH(2), .LAST_PTR_VALUE(1), .DEPTH_COUNT_VALUE(2), .ALMOST_FULL_LEVEL(1), .ALMOST_EMPTY_LEVEL(1), .ALMOST_FULL_COUNT_VALUE(1), .ALMOST_EMPTY_COUNT_VALUE(1), .USE_REGISTERED_READ(0), .ALMOST_EMPTY_USES_EMPTY(0), .ASYNC_RESET(0)) t0_fifo (
    .clk          (clk),
    .rst_n        (~rst),
    .wr_en        (chan_t0_wvalid),
    .wr_data      (chan_t0_wdata),
    .full         (chan_t0_full),
    .almost_full  (chan_t0_almost_full),
    .rd_en        (chan_t0_rready),
    .rd_data      (chan_t0_rdata),
    .empty        (chan_t0_empty),
    .almost_empty (chan_t0_almost_empty)
  );
  wire        _GEN = ~chan_t0_full;
  wire        _GEN_0 = chan_t0_prod1_producer_wvalid & ~chan_t0_prod0_main_wvalid;
  assign chan_t0_wvalid = chan_t0_prod0_main_wvalid | chan_t0_prod1_producer_wvalid;
  assign chan_t0_wdata =
    chan_t0_prod0_main_wvalid
      ? chan_t0_prod0_main_wdata
      : _GEN_0 ? chan_t0_prod1_producer_wdata : 32'h0;
  assign chan_t0_prod0_main_wready = chan_t0_prod0_main_wvalid & _GEN;
  assign chan_t0_prod1_producer_wready = _GEN_0 & _GEN;
  assign chan_t0_rvalid = ~chan_t0_empty;
  mygo_fifo #(.DATA_WIDTH(32), .DEPTH(2), .ADDR_WIDTH(1), .COUNT_WIDTH(2), .LAST_PTR_VALUE(1), .DEPTH_COUNT_VALUE(2), .ALMOST_FULL_LEVEL(1), .ALMOST_EMPTY_LEVEL(1), .ALMOST_FULL_COUNT_VALUE(1), .ALMOST_EMPTY_COUNT_VALUE(1), .USE_REGISTERED_READ(0), .ALMOST_EMPTY_USES_EMPTY(0), .ASYNC_RESET(0)) t1_fifo (
    .clk          (clk),
    .rst_n        (~rst),
    .wr_en        (chan_t1_wvalid),
    .wr_data      (chan_t1_wdata),
    .full         (chan_t1_full),
    .almost_full  (chan_t1_almost_full),
    .rd_en        (chan_t1_rready),
    .rd_data      (chan_t1_rdata),
    .empty        (chan_t1_empty),
    .almost_empty (chan_t1_almost_empty)
  );
  assign chan_t1_wready = ~chan_t1_full;
  assign chan_t1_rvalid = ~chan_t1_empty;
  reg signed [31:0] varargs;
  initial
    varargs = 32'h0;
  reg  [2:0]  state_reg22;
  initial
    state_reg22 = 3'h0;
  reg  [31:0] recv_reg24;
  reg signed [31:0] print_reg26;
  initial
    print_reg26 = 32'h0;
  assign chan_t0_prod0_main_wvalid = state_reg22 == 3'h4;
  assign chan_t0_prod0_main_wdata = chan_t0_prod0_main_wvalid ? recv_reg24 : 32'h0;
  assign chan_t1_rready = state_reg22 == 3'h1;
  always @(posedge clk) begin
    if (rst)
      state_reg22 <= 3'h0;
    else begin
      case (state_reg22)
        3'b000:
          state_reg22 <= 3'h1;
        3'b001: begin
          if (chan_t1_rvalid) begin
            recv_reg24 <= chan_t1_rdata;
            state_reg22 <= 3'h2;
          end
          else
            state_reg22 <= state_reg22;
        end
        3'b010: begin
          if (recv_reg24 == 32'h2A)
            state_reg22 <= 3'h3;
          else
            state_reg22 <= 3'h6;
        end
        3'b011:
          state_reg22 <= 3'h4;
        3'b100: begin
          if (chan_t0_prod0_main_wready)
            state_reg22 <= 3'h5;
          else
            state_reg22 <= state_reg22;
        end
        3'b101:
          state_reg22 <= 3'h6;
        3'b110: begin
          print_reg26 = recv_reg24;
          $write("phi loop final=%0d\n", print_reg26);
          state_reg22 <= 3'h7;
        end
        3'b111:
          state_reg22 <= state_reg22;
        default:
          state_reg22 <= state_reg22;
      endcase
    end
  end // always @(posedge)
  main__proc_consumer consumer_inst0 (
    .clk            (clk),
    .rst            (rst),
    .chan_t0_rdata  (chan_t0_rdata),
    .chan_t0_rvalid (chan_t0_rvalid),
    .chan_t0_rready (chan_t0_rready),
    .chan_t1_wdata  (chan_t1_wdata),
    .chan_t1_wvalid (chan_t1_wvalid),
    .chan_t1_wready (chan_t1_wready)
  );
  main__proc_producer producer_inst1 (
    .clk            (clk),
    .rst            (rst),
    .chan_t0_wdata  (chan_t0_prod1_producer_wdata),
    .chan_t0_wvalid (chan_t0_prod1_producer_wvalid),
    .chan_t0_wready (chan_t0_prod1_producer_wready)
  );
endmodule

module main__proc_consumer(
  input        clk,
               rst,
  inout signed [31:0] chan_t0_rdata,
  inout        chan_t0_rvalid,
               chan_t0_rready,
  inout signed [31:0] chan_t1_wdata,
  inout        chan_t1_wvalid,
               chan_t1_wready
);

  reg  [3:0]  state_reg51;
  initial
    state_reg51 = 4'h0;
  reg  [31:0] recv_reg53;
  reg signed [31:0] print_reg55;
  initial
    print_reg55 = 32'h0;
  reg signed [31:0] print_reg57;
  initial
    print_reg57 = 32'h0;
  reg  [31:0] phi_reg59;
  reg  [31:0] phi_reg61;
  wire [31:0] _GEN = phi_reg59 + recv_reg53;
  assign chan_t1_wvalid = state_reg51 == 4'h3;
  assign chan_t1_wdata = chan_t1_wvalid ? phi_reg59 : 32'sh0;
  assign chan_t0_rready = state_reg51 == 4'h6;
  always @(posedge clk) begin
    if (rst)
      state_reg51 <= 4'h0;
    else begin
      case (state_reg51)
        4'b0000: begin
          state_reg51 <= 4'h1;
          phi_reg59 <= 32'h0;
          phi_reg61 <= 32'h0;
        end
        4'b0001: begin
          if ($signed(phi_reg61) < 32'sh4)
            state_reg51 <= 4'h5;
          else
            state_reg51 <= 4'h2;
        end
        4'b0010:
          state_reg51 <= 4'h3;
        4'b0011: begin
          if (chan_t1_wready)
            state_reg51 <= 4'h4;
          else
            state_reg51 <= state_reg51;
        end
        4'b0100:
          state_reg51 <= 4'h8;
        4'b0101:
          state_reg51 <= 4'h6;
        4'b0110: begin
          if (chan_t0_rvalid) begin
            recv_reg53 <= chan_t0_rdata;
            state_reg51 <= 4'h7;
          end
          else
            state_reg51 <= state_reg51;
        end
        4'b0111: begin
          print_reg55 = recv_reg53;
          print_reg57 = _GEN;
          $write("consumer received %0d (running total %0d)\n",
                  print_reg55, print_reg57);
          state_reg51 <= 4'h1;
          phi_reg59 <= _GEN;
          phi_reg61 <= phi_reg61 + 32'h1;
        end
        4'b1000:
          state_reg51 <= state_reg51;
        default:
          state_reg51 <= state_reg51;
      endcase
    end
  end // always @(posedge)
endmodule

module main__proc_producer(
  input        clk,
               rst,
  inout signed [31:0] chan_t0_wdata,
  inout        chan_t0_wvalid,
               chan_t0_wready
);

  reg [2:0]  state_reg86;
  initial
    state_reg86 = 3'h0;
  reg signed [31:0] print_reg88;
  initial
    print_reg88 = 32'h0;
  reg [31:0] phi_reg90;
  assign chan_t0_wvalid = state_reg86 == 3'h4;
  assign chan_t0_wdata = chan_t0_wvalid ? phi_reg90 : 32'sh0;
  always @(posedge clk) begin
    if (rst)
      state_reg86 <= 3'h0;
    else begin
      case (state_reg86)
        3'b000: begin
          state_reg86 <= 3'h1;
          phi_reg90 <= 32'h0;
        end
        3'b001: begin
          if ($signed(phi_reg90) < 32'sh4)
            state_reg86 <= 3'h3;
          else
            state_reg86 <= 3'h2;
        end
        3'b010:
          state_reg86 <= 3'h6;
        3'b011:
          state_reg86 <= 3'h4;
        3'b100: begin
          if (chan_t0_wready)
            state_reg86 <= 3'h5;
          else
            state_reg86 <= state_reg86;
        end
        3'b101: begin
          print_reg88 = phi_reg90;
          $write("producer sent %0d\n", print_reg88);
          state_reg86 <= 3'h1;
          phi_reg90 <= phi_reg90 + 32'h1;
        end
        3'b110:
          state_reg86 <= state_reg86;
        default:
          state_reg86 <= state_reg86;
      endcase
    end
  end // always @(posedge)
endmodule


module mygo_fifo #(
  parameter integer DATA_WIDTH = 32,
  parameter integer DEPTH = 1,
  parameter integer ADDR_WIDTH = 1,
  parameter integer COUNT_WIDTH = 1,
  parameter integer LAST_PTR_VALUE = 0,
  parameter integer DEPTH_COUNT_VALUE = 1,
  parameter integer ALMOST_FULL_LEVEL = 1,
  parameter integer ALMOST_EMPTY_LEVEL = 0,
  parameter integer ALMOST_FULL_COUNT_VALUE = 1,
  parameter integer ALMOST_EMPTY_COUNT_VALUE = 0,
  parameter bit USE_REGISTERED_READ = 1'b0,
  parameter bit ALMOST_EMPTY_USES_EMPTY = 1'b1,
  parameter bit ASYNC_RESET = 1'b0
) (
  input  wire                   clk,
  input  wire                   rst_n,
  input  wire                   wr_en,
  input  wire [DATA_WIDTH-1:0]  wr_data,
  output wire                   full,
  output wire                   almost_full,
  input  wire                   rd_en,
  output wire [DATA_WIDTH-1:0]  rd_data,
  output wire                   empty,
  output wire                   almost_empty
);

  localparam [ADDR_WIDTH-1:0] LAST_PTR = ADDR_WIDTH'(LAST_PTR_VALUE);
  localparam [COUNT_WIDTH-1:0] DEPTH_COUNT = COUNT_WIDTH'(DEPTH_COUNT_VALUE);
  localparam [COUNT_WIDTH-1:0] ALMOST_FULL_COUNT = COUNT_WIDTH'(ALMOST_FULL_COUNT_VALUE);
  localparam [COUNT_WIDTH-1:0] ALMOST_EMPTY_COUNT = COUNT_WIDTH'(ALMOST_EMPTY_COUNT_VALUE);

  reg [DATA_WIDTH-1:0] mem [0:DEPTH-1];
  reg [ADDR_WIDTH-1:0] wr_ptr;
  reg [ADDR_WIDTH-1:0] rd_ptr;
  reg [COUNT_WIDTH-1:0] count;

  wire wr_fire = wr_en && !full;
  wire rd_fire = rd_en && !empty;
  wire [ADDR_WIDTH-1:0] wr_ptr_next = (wr_ptr == LAST_PTR) ? {ADDR_WIDTH{1'b0}} : (wr_ptr + 1'b1);
  wire [ADDR_WIDTH-1:0] rd_ptr_next = (rd_ptr == LAST_PTR) ? {ADDR_WIDTH{1'b0}} : (rd_ptr + 1'b1);

  assign full = (count == DEPTH_COUNT);
  assign empty = (count == {COUNT_WIDTH{1'b0}});
  assign almost_full = (count >= ALMOST_FULL_COUNT);
  assign almost_empty = (ALMOST_EMPTY_USES_EMPTY != 1'b0) ? empty : (count <= ALMOST_EMPTY_COUNT);

  generate
    if (USE_REGISTERED_READ != 1'b0) begin : gen_registered_read
      reg [DATA_WIDTH-1:0] rd_data_reg;
      assign rd_data = empty ? {DATA_WIDTH{1'b0}} : rd_data_reg;

      if (ASYNC_RESET != 1'b0) begin : gen_async_reset
        always @(posedge clk or negedge rst_n) begin
          if (!rst_n) begin
            wr_ptr <= {ADDR_WIDTH{1'b0}};
            rd_ptr <= {ADDR_WIDTH{1'b0}};
            count <= {COUNT_WIDTH{1'b0}};
            rd_data_reg <= {DATA_WIDTH{1'b0}};
          end else begin
            if (wr_fire) begin
              mem[wr_ptr] <= wr_data;
              wr_ptr <= wr_ptr_next;
            end
            if (rd_fire) begin
              rd_ptr <= rd_ptr_next;
            end
            case ({wr_fire, rd_fire})
              2'b10: count <= count + 1'b1;
              2'b01: count <= count - 1'b1;
              default: count <= count;
            endcase
            if (empty && wr_fire) begin
              rd_data_reg <= wr_data;
            end else if (rd_fire) begin
              if (count > 1) begin
                rd_data_reg <= mem[rd_ptr_next];
              end else if (wr_fire) begin
                rd_data_reg <= wr_data;
              end else begin
                rd_data_reg <= {DATA_WIDTH{1'b0}};
              end
            end else if (!empty) begin
              rd_data_reg <= mem[rd_ptr];
            end
          end
        end
      end else begin : gen_sync_reset
        always @(posedge clk) begin
          if (!rst_n) begin
            wr_ptr <= {ADDR_WIDTH{1'b0}};
            rd_ptr <= {ADDR_WIDTH{1'b0}};
            count <= {COUNT_WIDTH{1'b0}};
            rd_data_reg <= {DATA_WIDTH{1'b0}};
          end else begin
            if (wr_fire) begin
              mem[wr_ptr] <= wr_data;
              wr_ptr <= wr_ptr_next;
            end
            if (rd_fire) begin
              rd_ptr <= rd_ptr_next;
            end
            case ({wr_fire, rd_fire})
              2'b10: count <= count + 1'b1;
              2'b01: count <= count - 1'b1;
              default: count <= count;
            endcase
            if (empty && wr_fire) begin
              rd_data_reg <= wr_data;
            end else if (rd_fire) begin
              if (count > 1) begin
                rd_data_reg <= mem[rd_ptr_next];
              end else if (wr_fire) begin
                rd_data_reg <= wr_data;
              end else begin
                rd_data_reg <= {DATA_WIDTH{1'b0}};
              end
            end else if (!empty) begin
              rd_data_reg <= mem[rd_ptr];
            end
          end
        end
      end
    end else begin : gen_direct_read
      assign rd_data = empty ? {DATA_WIDTH{1'b0}} : mem[rd_ptr];

      if (ASYNC_RESET != 1'b0) begin : gen_async_reset
        always @(posedge clk or negedge rst_n) begin
          if (!rst_n) begin
            wr_ptr <= {ADDR_WIDTH{1'b0}};
            rd_ptr <= {ADDR_WIDTH{1'b0}};
            count <= {COUNT_WIDTH{1'b0}};
          end else begin
            if (wr_fire) begin
              mem[wr_ptr] <= wr_data;
              wr_ptr <= wr_ptr_next;
            end
            if (rd_fire) begin
              rd_ptr <= rd_ptr_next;
            end
            case ({wr_fire, rd_fire})
              2'b10: count <= count + 1'b1;
              2'b01: count <= count - 1'b1;
              default: count <= count;
            endcase
          end
        end
      end else begin : gen_sync_reset
        always @(posedge clk) begin
          if (!rst_n) begin
            wr_ptr <= {ADDR_WIDTH{1'b0}};
            rd_ptr <= {ADDR_WIDTH{1'b0}};
            count <= {COUNT_WIDTH{1'b0}};
          end else begin
            if (wr_fire) begin
              mem[wr_ptr] <= wr_data;
              wr_ptr <= wr_ptr_next;
            end
            if (rd_fire) begin
              rd_ptr <= rd_ptr_next;
            end
            case ({wr_fire, rd_fire})
              2'b10: count <= count + 1'b1;
              2'b01: count <= count - 1'b1;
              default: count <= count;
            endcase
          end
        end
      end
    end
  endgenerate
endmodule
